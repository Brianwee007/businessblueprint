function updateInstructor(id, field, val){
  const ins = instructors.find(i => i.id === id);
  if(!ins) return;
  ins[field] = (field === 'name' || field === 'role' || field === 'payType' || field === 'taxType') ? val : (parseFloat(val)||0);
  if(field === 'role' || field === 'payType') renderInstructors();
  else refreshInstructorCost(id);
}

function calcMonthlyCost(ins){
  const hrs = ins.hoursPerWeek || 0;
  switch(ins.payType){
    case 'per_lesson':   return ins.payRate * hrs * 4.3;
    case 'per_hour':     return ins.payRate * hrs * 4.3;
    case 'parttime_sal': return ins.payRate / 12;
    case 'fulltime_sal': return ins.payRate / 12;
    default: return 0;
  }
}

function refreshInstructorCost(id){
  const ins = instructors.find(i => i.id === id);
  if(!ins) return;
  const el = document.getElementById(`instr_cost_${id}`);
  if(el) el.textContent = '$' + fmt(calcMonthlyCost(ins));
  refreshInstructorTotal();
}

function refreshInstructorTotal(){
  const total = instructors.reduce((s,i) => s + calcMonthlyCost(i), 0);
  const hint = document.getElementById('instructorTotalHint');
  if(hint) hint.innerHTML = `<div style="margin-top:8px;font-size:12px;color:var(--muted);padding:6px 10px;background:var(--cream);border-radius:3px;border:1px solid var(--border)">
