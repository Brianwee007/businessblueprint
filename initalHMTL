        <div class="fg w3"><label>Avg Lesson Duration (min)</label><input type="number" id="goalLessonDur" value="60" min="30" max="90" step="15"></div>
        <div class="fg w3"><label>New Students / Month</label><input type="number" id="newPerMonth" value="6" min="0"></div>
      </div>

      <!-- Horse welfare -->
      <div style="border-top:1px solid var(--border);margin:12px 0 10px;padding-top:12px">
        <div style="font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:10px">🐴 Horse Welfare Limits</div>
        <div class="frow">
          <div class="fg w3">
            <label>Max Hours / Week per Horse</label>
            <input type="number" id="horseMaxWeek" value="10" min="1" max="40" onchange="renderGoalResources()">
            <span class="hint">Typical school horse: 8–15 hrs/week</span>
          </div>
          <div class="fg w3">
            <label>Max Hours / Day per Horse</label>
            <input type="number" id="horseMaxDay" value="2" min="1" max="8" onchange="renderGoalResources()">
            <span class="hint">Typical school horse: 2–4 hrs/day</span>
          </div>
          <div class="fg w3">
            <label>Days Off per Horse per Week</label>
            <input type="number" id="horseDaysOff" value="1" min="0" max="3" onchange="renderGoalResources()">
            <span class="hint">Min 1 rest day recommended</span>
          </div>
        </div>
