<script>
// ═══════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════
let horses = [];
let nextHorseId = 1;
let currentRevenue = 0;
let goalRevenue = 0;
let agreementsSigned = false;
let agreementsGenerated = false;
let scheduleBuilt = false;

// ═══════════════════════════════════════════════
// PHASE NAV
// ═══════════════════════════════════════════════
const PHASES = ['1 Current State','2 Diagnosis','3 Membership','4 Agreements','5 Goal Schedule','6 Compare'];

function buildPhaseNav(){
  document.getElementById('phaseTrack').innerHTML = PHASES.map((l,i) =>
    `<button class="pt${i===0?' active':''}" id="pt${i}" onclick="goTo(${i})">${l}</button>`
  ).join('');
}

function goTo(i){
  document.querySelectorAll('.phase').forEach((p,j) => p.classList.toggle('on', j===i));
  document.querySelectorAll('.pt').forEach((t,j) => {
    t.classList.toggle('active', j===i);
    t.classList.toggle('done', j<i);
  });
  document.getElementById('progFill').style.width = ((i+1)/6*100)+'%';
  window.scrollTo({top:0,behavior:'smooth'});
}

// ═══════════════════════════════════════════════
// HORSE MANAGEMENT
// ═══════════════════════════════════════════════
function addHorse(name='', age='', height='', notes=''){
  const id = nextHorseId++;
  horses.push({id, name, age, height, notes});
  renderHorses();
}

function removeHorse(id){
  horses = horses.filter(h => h.id !== id);
  renderHorses();
}

function renderHorses(){
  const el = document.getElementById('horseList');
  if(horses.length === 0){
    el.innerHTML = '<div style="color:var(--muted);font-size:12px;padding:8px">No horses added yet.</div>';
    return;
  }
  el.innerHTML = horses.map(h => `
    <div class="horse-row">
      <input type="text" value="${esc(h.name)}" placeholder="Horse name" onchange="updateHorse(${h.id},'name',this.value)">
      <input type="number" value="${h.age||''}" placeholder="Age" min="1" max="35" onchange="updateHorse(${h.id},'age',this.value)" style="text-align:center">
      <input type="text" value="${esc(h.height||'')}" placeholder='e.g. 15.2' onchange="updateHorse(${h.id},'height',this.value)" style="text-align:center">
      <input type="number" value="${h.notes||''}" placeholder="e.g. 20" min="0" max="60" onchange="updateHorse(${h.id},'notes',this.value)" style="text-align:center">
      <button class="del-btn" onclick="removeHorse(${h.id})">✕</button>
    </div>`).join('');
}

function updateHorse(id, field, val){
  const h = horses.find(h => h.id === id);
  if(h) h[field] = val;
}

// ═══════════════════════════════════════════════
// PHASE 1: CURRENT CALC
// ═══════════════════════════════════════════════
function calcCurrentAndNext(){
  const nums = getInputNums();

  // Collect horse data
  horses.forEach(h => {
    const row = document.querySelector(`[data-horse-id="${h.id}"]`);
  });

  // Weekly lessons
  const wkPrivate = nums.wkPrivate, wkGroup = nums.wkGroup, wkSemi = nums.wkSemi, wkEval = nums.wkEval;
  const totalWeeklyLessons = wkPrivate + wkGroup + wkSemi + wkEval;

  // Revenue per month — membership model overrides per-lesson calc
  const chargeModel = document.querySelector('input[name=chargeModel]:checked').value;
  const memRev = getMemRevenue();

  // For per-lesson: use per-type student counts from paygo inputs if available
  const getPaygoStudents = (id) => parseInt(document.getElementById(`paygo_students_${id}`)?.value)||0;
  const paygoPrivate = getPaygoStudents('pricePrivate');
  const paygoGroup   = getPaygoStudents('priceGroup');
  const paygoSemi    = getPaygoStudents('priceSemi');
  const paygoEval    = getPaygoStudents('priceEval');
  const lessonRevWeek = paygoPrivate*nums.pricePrivate + paygoGroup*nums.priceGroup + paygoSemi*nums.priceSemi + paygoEval*nums.priceEval;
  const monthlyRev = memRev !== null ? memRev : lessonRevWeek * 4.3;

  // Horse hours
  const durFactor = nums.lessonDur / 60;
  const groupRiders = nums.groupRiders;
  const horseHrsPerWeek = (wkPrivate*1 + wkGroup*groupRiders + wkSemi*2 + wkEval*1) * durFactor;
  const numHorses = horses.length || 1;
  const hrsPerHorse = horseHrsPerWeek / numHorses;

  // Instructor hours & efficiency
  const instrHrsPerWeek = totalWeeklyLessons * durFactor;
  const instrCostPerMonth = instrHrsPerWeek * 4.3 * nums.instrRate;
  const instrRevPerHour = instrHrsPerWeek > 0 ? (monthlyRev / (instrHrsPerWeek * 4.3)) : 0;

  currentRevenue = monthlyRev;

  // Board/training from horse accommodations (needed for KPIs too)
  const diagBoardRev    = stallRows.filter(s => s.use === 'boarder' || s.use === 'boarder_lesson').reduce((sum, s) => sum + (s.board || 0), 0);
  const diagTrainingRev = stallRows.filter(s => ['boarder','boarder_lesson','personal','investment','broodmare','stallion','homebred'].includes(s.use)).reduce((sum, s) => sum + (s.training || 0), 0);
  const diagHorseOwnerRev = diagBoardRev + diagTrainingRev;
  const diagTotalRev = monthlyRev + diagHorseOwnerRev;

  // Instructor % of lesson revenue
  const instrPctOfLesson = monthlyRev > 0 ? (instrCostPerMonth / monthlyRev) * 100 : 0;
  const instrPctClass = instrPctOfLesson < 35 ? 'hi' : instrPctOfLesson < 50 ? 'mid-c' : 'lo';
  const instrPctLabel = instrPctOfLesson < 35 ? '🟢 Healthy margin' : instrPctOfLesson < 50 ? '🟡 Watch this' : '🔴 High — review pay structure';

  // KPIs
  const diagKpiHtml = `
    <div class="kpis">
      <div class="kpi mid-c">
        <div class="kl">Est. Total Monthly Revenue</div>
        <div class="kv">$${fmt(diagTotalRev)}</div>
        <div class="ks" style="line-height:1.5">
          🐴 Lessons $${fmt(monthlyRev)}${chargeModel==='per_lesson'?' ⚠️':''}<br>
          🏡 Horse owners $${fmt(diagHorseOwnerRev)}
        </div>
      </div>
      <div class="kpi ${hrsPerHorse < 5 ? 'hi' : hrsPerHorse < 10 ? 'mid-c' : 'lo'}">
        <div class="kl">Hrs / Horse / Week</div><div class="kv">${hrsPerHorse.toFixed(1)}</div>
        <div class="ks">${hrsPerHorse < 5 ? '🟢 Plenty of capacity' : hrsPerHorse < 10 ? '🟡 Getting full' : '🔴 Near max — need horses'}</div>
      </div>
      <div class="kpi ${instrRevPerHour > 120 ? 'hi' : instrRevPerHour > 80 ? 'mid-c' : 'lo'}">
        <div class="kl">Revenue / Instructor Hour</div><div class="kv">$${instrRevPerHour.toFixed(0)}</div>
        <div class="ks">${instrRevPerHour > 120 ? '🟢 Strong efficiency' : instrRevPerHour > 80 ? '🟡 Room to improve' : '🔴 Too many privates'}</div>
      </div>
      <div class="kpi ${instrPctClass}">
        <div class="kl">Instructor Cost as % of Lesson Rev</div>
        <div class="kv">${instrPctOfLesson.toFixed(0)}%</div>
        <div class="ks">$${fmt(instrCostPerMonth)} ÷ $${fmt(monthlyRev)} · ${instrPctLabel}</div>
      </div>
      <div class="kpi info"><div class="kl">Instructor Cost / Month</div><div class="kv">$${fmt(instrCostPerMonth)}</div><div class="ks">${instrHrsPerWeek.toFixed(1)} hrs/wk × 4.3</div></div>
      <div class="kpi info"><div class="kl">Lessons / Week</div><div class="kv">${totalWeeklyLessons}</div><div class="ks">${numHorses} horses, ${nums.numInstructors} instructors</div></div>
      <div class="kpi info"><div class="kl">Annual Revenue Est.</div><div class="kv">$${fmt(diagTotalRev * (nums.weeksOpen/4))}</div><div class="ks">${nums.weeksOpen} weeks open</div></div>
    </div>`;

  document.getElementById('diagKpis').innerHTML = diagKpiHtml;

  // Insights & membership pitch — built below, then rendered after revenue table
  let insights = '';
  let membershipPitch = '';

  // ── Revenue Breakdown Table ──────────────────
  // Pull boarding/training revenue directly from horse accommodations
  const boardRev    = stallRows.filter(s => s.use === 'boarder' || s.use === 'boarder_lesson').reduce((sum, s) => sum + (s.board || 0), 0);
  const trainingRev = stallRows.filter(s => ['boarder','boarder_lesson','personal','investment','broodmare','stallion','homebred'].includes(s.use)).reduce((sum, s) => sum + (s.training || 0), 0);
  const horseOwnerRev = boardRev + trainingRev;
  const totalAllRev   = monthlyRev + horseOwnerRev;

  const revRowStyle = 'padding:9px 14px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;font-size:13px';
  const revTotalStyle = 'padding:10px 14px;display:flex;justify-content:space-between;align-items:center;font-size:14px;font-weight:700;background:var(--cream)';

  const boardRows = boardRev > 0 || trainingRev > 0 ? `
    <div style="${revRowStyle};padding-left:28px;font-size:12px;color:var(--muted)">
      <span>Board (boarders & boarder/lesson horses)</span><span>$${fmt(boardRev)}/mo</span>
    </div>
    <div style="${revRowStyle};padding-left:28px;font-size:12px;color:var(--muted)">
      <span>Training & lessons on owner's horses</span><span>$${fmt(trainingRev)}/mo</span>
    </div>` : `
    <div style="${revRowStyle};padding-left:28px;font-size:12px;color:var(--muted);font-style:italic">
      <span>No board or training revenue entered in Horse Accommodations</span><span>$0/mo</span>
    </div>`;

  const revBreakdown = `
    <div class="card" style="margin-top:0">
      <div class="card-h"><span class="ico">💰</span><span class="ttl">Monthly Revenue Breakdown</span></div>
      <div class="card-b" style="padding:0">
        <div style="${revRowStyle};background:#FFFDF5;font-weight:600;color:var(--brown)">
          <span>🐴 Lessons on School Horses</span>
          <span style="font-size:15px;font-weight:700;color:var(--brown)">$${fmt(monthlyRev)}/mo</span>
        </div>
        <div style="${revRowStyle};background:#F0FAF5;font-weight:600;color:#1A5C3A">
          <span>🏡 Horse Owner Revenue</span>
          <span style="font-size:15px;font-weight:700;color:#1A5C3A">$${fmt(horseOwnerRev)}/mo</span>
        </div>
        ${boardRows}
        <div style="${revTotalStyle};border-top:2px solid var(--border)">
          <span>Total Estimated Monthly Revenue</span>
          <span style="font-size:16px;color:var(--brown)">$${fmt(totalAllRev)}/mo</span>
        </div>
        ${horseOwnerRev === 0 ? `<div style="padding:8px 14px;font-size:11px;color:var(--muted);border-top:1px solid var(--border)">💡 Enter board and training amounts in <strong>Horse Accommodations</strong> to see your full revenue picture here.</div>` : ''}
      </div>
    </div>`;

  // Build insights first, then render revenue table + insights together at the end

  if(chargeModel === 'per_lesson'){
    insights += I('ib','⚠️',`<strong>You're charging per lesson — this is the #1 reason riding schools struggle with cash flow.</strong> When it rains, clients cancel. When kids go on vacation, income drops. When someone gets sick — you don't get paid. You're essentially running a restaurant that only charges when someone eats.`);
  }

  if(hrsPerHorse < 5){
    const roomFor = Math.floor((10 - hrsPerHorse) * numHorses / durFactor);
    insights += I('ig','🐴',`Your ${numHorses} lesson horses are only working <strong>${hrsPerHorse.toFixed(1)} hours each per week</strong>. At a safe maximum of 10 hours/week, you could add approximately <strong>${roomFor} more lessons per week</strong> without buying a single additional horse. That's pure upside.`);
  } else if(hrsPerHorse > 10){
    insights += I('ib','🐴',`Your horses are working <strong>${hrsPerHorse.toFixed(1)} hours/week each</strong> — this is above the 10hr/week guideline. You may be risking soundness issues and burnout. You'll need more horses before you can grow significantly.`);
  }

  if(instrRevPerHour < 80){
    const priv = nums.wkPrivate, grp = nums.wkGroup;
    insights += I('iw','👩‍🏫',`You're generating only <strong>$${instrRevPerHour.toFixed(0)} in revenue per instructor hour</strong>. The benchmark is $100+. The fix: shift more lessons to groups of 4-5. A single instructor teaching 5 students in a group generates 5× the revenue per hour vs. a private lesson at the same rate.`);
  }

  if(instrRevPerHour > 0){
    const potentialGroupOnly = (wkGroup + wkPrivate + wkSemi) * nums.priceGroup * groupRiders * 4;
    insights += I('ii','📊',`<strong>Lesson horse efficiency KPI:</strong> ${horseHrsPerWeek.toFixed(1)} total horse-hours ÷ ${numHorses} horses = ${hrsPerHorse.toFixed(1)} hrs/horse/week. <strong>Instructor revenue efficiency:</strong> $${fmt(monthlyRev)} ÷ ${instrHrsPerWeek.toFixed(1)} instructor hours = $${instrRevPerHour.toFixed(0)}/hr taught.`);
  }

  if(chargeModel === 'per_lesson' || chargeModel === 'mixed'){
    const currentAvgPerStudent = monthlyRev / Math.max(nums.totalStudents, 1);
    const membershipLow = Math.round(nums.pricePrivate * 0.75 * 8);
    const membershipHigh = Math.round(nums.pricePrivate * 0.85 * 8);
    membershipPitch = `
      <div class="card">
        <div class="card-h"><span class="ico">💡</span><span class="ttl">There's a Much Better Way to Price Your Program</span></div>
        <div class="card-b">
          <p style="font-size:14px;line-height:1.8;margin-bottom:14px">Right now you're averaging <strong>$${currentAvgPerStudent.toFixed(0)}/month per student</strong>. You're also exposed to every cancellation. Here's what the most profitable riding schools do differently:</p>
          <div class="ins ig"><span class="ico">🔑</span><span><strong>The Membership Model:</strong> Instead of $${nums.pricePrivate} per lesson, charge a monthly membership that includes 1 ride per week <em>plus</em> access to a weekly group unmounted horsemanship class. Clients now come 8 times a month instead of 4 — and your income doesn't drop when it rains.</span></div>
          <div class="ins ig"><span class="ico">📐</span><span><strong>The pricing math:</strong> Take your current lesson price of $${nums.pricePrivate} and multiply by 0.75–0.85 (so clients feel they're getting 15-25% better value), then multiply by 8 classes. That's a suggested range of <strong>$${membershipLow}–$${membershipHigh}/month</strong>. Clients do the math: $${membershipHigh}÷8 = $${(membershipHigh/8).toFixed(0)}/class. They feel like they're winning.</span></div>
          <div class="ins ig"><span class="ico">📅</span><span><strong>Charge every 4 weeks, not monthly.</strong> There are 13 four-week cycles in a year vs. 12 months. At $${membershipLow}/cycle that's $${fmt(membershipLow*13)} annually vs. $${fmt(membershipLow*12)} monthly — roughly 8% more revenue from the same clients. For a school at breakeven, that extra 8% can be the entire profit margin.</span></div>
          <div class="pricing-band">
            <div><div class="band-label">Suggested Tier 1 Range</div><div class="band-range">$${membershipLow} – $${membershipHigh}</div><div class="band-label">every 4 weeks</div></div>
            <div style="margin-left:20px;font-size:13px;color:var(--muted)">Based on your current $${nums.pricePrivate} private lesson price × 0.75–0.85 × 8 classes/month</div>
          </div>
        </div>
      </div>`;
  }

  document.getElementById('diagInsights').innerHTML = revBreakdown + insights;
  document.getElementById('diagMembership').innerHTML = membershipPitch;

  // Pre-fill membership pricing suggestions
  const priceLow = Math.round(nums.pricePrivate * 0.75 * 8 / 10) * 10;
  const priceHigh = Math.round(nums.pricePrivate * 0.85 * 8 / 10) * 10;
  const suggestedT1 = Math.round((priceLow + priceHigh) / 2 / 10) * 10;

  document.getElementById('t1Price').value = suggestedT1;
  document.getElementById('t2Price').value = suggestedT1 * 2;
  document.getElementById('t3Price').value = suggestedT1 * 3;
  updateAnnualPrices();

  // Tier suggestions
  document.getElementById('tier1Suggestion').innerHTML = `<div class="pricing-band"><div><div class="band-label">Suggested range</div><div class="band-range">$${priceLow}–$${priceHigh}</div></div><div style="margin-left:16px;font-size:12px;color:var(--muted)">Based on $${nums.pricePrivate} × 0.75–0.85 × 8 sessions</div></div>`;
  document.getElementById('tier2Suggestion').innerHTML = `<div class="pricing-band"><div><div class="band-label">Suggested range</div><div class="band-range">$${priceLow*2}–$${priceHigh*2}</div></div><div style="margin-left:16px;font-size:12px;color:var(--muted)">Simply 2× Tier 1. Don't discount — your costs don't go down.</div></div>`;
  document.getElementById('tier3Suggestion').innerHTML = `<div class="pricing-band"><div><div class="band-label">Suggested range</div><div class="band-range">$${priceLow*3}–$${priceHigh*3}</div></div><div style="margin-left:16px;font-size:12px;color:var(--muted)">Half-lease pricing. 2 lessons + 1 practice ride + show eligibility.</div></div>`;

  buildPerks();
  updateMembershipCalc();

  goTo(1);
}

function updateAnnualPrices(){
  const t1 = parseFloat(document.getElementById('t1Price').value)||0;
  const t2 = parseFloat(document.getElementById('t2Price').value)||0;
  const t3 = parseFloat(document.getElementById('t3Price').value)||0;
  // 13 cycles × 0.85 = annual with 15% off
  const annFn = p => Math.round(p * 13 * 0.85 / 10) * 10;
  document.getElementById('t1Annual').placeholder = '$'+fmt(annFn(t1));
  document.getElementById('t2Annual').placeholder = '$'+fmt(annFn(t2));
  document.getElementById('t3Annual').placeholder = '$'+fmt(annFn(t3));
}

function updateMembershipCalc(){
  updateAnnualPrices();
}

const PERKS_T1 = ['Weekly group unmounted horsemanship class','Annual lesson calendar published in advance','Priority scheduling','Member-only newsletter'];
const PERKS_T2 = ['Show eligibility on lesson horses (additional cost)','2 guest passes per year','Early camp/clinic registration','Monthly progress report'];
const PERKS_T3 = ['Designated lesson horse (when available)','Practice ride (unmounted or light hack)','Half-lease show eligibility','3 guest passes per year','Quarterly private coaching session'];

function buildPerks(){
  const build = (containerId, perks, name) => {
    document.getElementById(containerId).innerHTML = perks.map((p,i) => `
      <div class="perk-opt">
        <input type="checkbox" id="${name}_${i}" value="${p}" checked>
        <label for="${name}_${i}">${p}</label>
      </div>`).join('');
  };
  build('t1Perks', PERKS_T1, 't1p');
  build('t2Perks', PERKS_T2, 't2p');
  build('t3Perks', PERKS_T3, 't3p');
}

function getSelectedPerks(name, perks){
  return perks.filter((_,i) => document.getElementById(`${name}_${i}`)?.checked);
}

// ═══════════════════════════════════════════════
// PHASE 3: AGREEMENTS
// ═══════════════════════════════════════════════
function signDisclaimer(){
  const name = document.getElementById('disclaimerName').value.trim();
  const date = document.getElementById('disclaimerDate').value;
  if(!name || !date){
    document.getElementById('disclaimerStatus').innerHTML = I('iw','⚠️','Please enter your name and date to continue.');
    return;
  }
  agreementsSigned = true;
  document.getElementById('disclaimerStatus').innerHTML = I('ig','✅',`Acknowledged by <strong>${name}</strong> on ${date}. Generating your agreements…`);
  document.getElementById('agreementSection').style.display = 'block';
  generateAgreements(name);
}

async function generateAgreements(signerName){
  const nums = getInputNums();
  const t1 = parseFloat(document.getElementById('t1Price').value)||300;
  const t2 = parseFloat(document.getElementById('t2Price').value)||600;
  const t3 = parseFloat(document.getElementById('t3Price').value)||900;
  const t1Ann = parseFloat(document.getElementById('t1Annual').value) || Math.round(t1*13*0.85/10)*10;
  const t2Ann = parseFloat(document.getElementById('t2Annual').value) || Math.round(t2*13*0.85/10)*10;
  const t3Ann = parseFloat(document.getElementById('t3Annual').value) || Math.round(t3*13*0.85/10)*10;
  const makeup = document.querySelector('input[name=makeupPolicy]:checked').value;
  const closure = document.getElementById('closureWeeks').value;
  const cancel = document.getElementById('cancelNotice').value;
  const t2commit = document.getElementById('t2Commit').value;
  const t3commit = document.getElementById('t3Commit').value;
  const state = nums.schoolState || 'your state';
  const school = nums.schoolName || 'the Riding School';

  const t1Perks = getSelectedPerks('t1p', PERKS_T1);
  const t2Perks = getSelectedPerks('t2p', PERKS_T2);
  const t3Perks = getSelectedPerks('t3p', PERKS_T3);

  const makeupText = {
    none: 'No makeup lessons are offered under any circumstances.',
    '1per_cycle': 'One (1) makeup lesson per billing cycle if cancelled at least 48 hours in advance. Makeup must be used in the following billing cycle or it expires.',
    '5tokens': 'Students receive five (5) makeup tokens per calendar year. Each token is issued only when a lesson is cancelled at least 48 hours in advance. Tokens expire 60 days after the missed lesson.'
  }[makeup];

  document.getElementById('agreementLoading').innerHTML = `<div class="ai-loading"><div class="spinner"></div><span>AI is generating all three agreements with ${state}-specific liability language…</span></div>`;

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:4000,
        messages:[{role:'user', content:`You are drafting three professional equine facility membership agreements for "${school}" located in ${state}. Write complete, polished, professional agreements ready for attorney review.

PRICING:
- Tier 1 (1×/week): $${t1} every 4 weeks | $${t1Ann}/year
