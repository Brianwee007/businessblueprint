    }
  } catch(err) {
    document.getElementById('agreementLoading').innerHTML = I('ib','❌',`Error generating agreements: ${err.message}. Please try again.`);
  }
}

function showAgreementTab(i){
  document.querySelectorAll('.agreement-box').forEach((b,j) => b.style.display = j===i?'block':'none');
  document.querySelectorAll('.atab').forEach((t,j) => t.classList.toggle('active', j===i));
}

function copyAgreement(i){
  const el = document.getElementById(`agr${i}`);
  if(!el) return;
  navigator.clipboard.writeText(el.innerText).then(() => alert('Agreement copied to clipboard!'));
}

function formatAgreement(text){
  return text
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
    .replace(/^(#{1,3} .+)$/gm, s => `<h3>${s.replace(/^#+\s*/,'')}</h3>`)
    .replace(/\n\n/g,'</p><p>')
    .replace(/^•\s?/gm,'• ')
    .replace(/^\n/,'<p>')
    + '</p>';
}

