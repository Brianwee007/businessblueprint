let goalLessons  = [];
let goalNextId   = 1;
let goalOpenDays = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

const GOAL_TYPES = {
  private: {label:'Private',     bg:'#FFF8DC', border:'#DDB840', color:'#7A5C00'},
