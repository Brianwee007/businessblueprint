// SCHOOL — OWNERS & PROPERTY
// ═══════════════════════════════════════════════
let owners = [
  {id:1, name:'', pct:100, role:'Owner / Operator'},
];
let nextOwnerId = 2;

function addOwner(){
  owners.push({id:nextOwnerId++, name:'', pct:0, role:''});
  renderOwners();
}

function removeOwner(id){
  owners = owners.filter(o => o.id !== id);
  renderOwners();
}

function updateOwner(id, field, val){
  const o = owners.find(o => o.id === id);
  if(!o) return;
  o[field] = field === 'pct' ? (parseFloat(val)||0) : val;
  refreshOwnershipTotal();
}

function refreshOwnershipTotal(){
  const total = owners.reduce((s,o) => s + (o.pct||0), 0);
  const warn  = document.getElementById('ownershipWarning');
  if(!warn) return;
  if(Math.abs(total - 100) < 0.01 || owners.length === 0){
    warn.style.display = 'none';
  } else {
    warn.style.display = 'block';
    warn.textContent = `Ownership totals ${total}% — should equal 100%.`;
  }
}

function renderOwners(){
  const tbody = document.getElementById('ownersTableBody');
  if(!tbody) return;
  tbody.innerHTML = owners.map(o => `
    <tr>
      <td style="padding:6px 8px 6px 10px;background:var(--cream);border:1px solid var(--border);border-right:none;border-radius:4px 0 0 4px">
        <input type="text" value="${esc(o.name)}" placeholder="Full name"
          style="width:100%;padding:5px 8px;font-size:13px;border:1.5px solid var(--border);background:rgba(255,255,255,.8);border-radius:3px;color:var(--brown)"
          oninput="updateOwner(${o.id},'name',this.value)">
      </td>
      <td style="padding:6px 8px;background:var(--cream);border-top:1px solid var(--border);border-bottom:1px solid var(--border);width:130px">
        <div style="position:relative">
          <input type="number" value="${o.pct}" min="0" max="100" step="0.01"
            style="width:100%;padding:5px 28px 5px 8px;font-size:13px;border:1.5px solid var(--border);background:rgba(255,255,255,.8);border-radius:3px;color:var(--brown);text-align:right"
            oninput="updateOwner(${o.id},'pct',this.value)">
          <span style="position:absolute;right:8px;top:50%;transform:translateY(-50%);font-size:12px;color:var(--muted);pointer-events:none">%</span>
        </div>
      </td>
      <td style="padding:6px 8px;background:var(--cream);border-top:1px solid var(--border);border-bottom:1px solid var(--border)">
        <input type="text" value="${esc(o.role)}" placeholder="e.g. Owner / Operator, Silent Partner…"
          style="width:100%;padding:5px 8px;font-size:13px;border:1.5px solid var(--border);background:rgba(255,255,255,.8);border-radius:3px;color:var(--brown)"
          oninput="updateOwner(${o.id},'role',this.value)">
      </td>
      <td style="padding:6px 8px 6px 4px;background:var(--cream);border:1px solid var(--border);border-left:none;border-radius:0 4px 4px 0">
        ${owners.length > 1
          ? `<button class="del-btn" onclick="removeOwner(${o.id})">✕</button>`
          : `<span style="display:inline-block;width:28px"></span>`}
      </td>
    </tr>`).join('');
  refreshOwnershipTotal();
}

function renderPropertyPayment(){
  const status = document.getElementById('schoolPropertyStatus')?.value || 'own';
  const field  = document.getElementById('propertyPaymentField');
  if(!field) return;

  if(status === 'own'){
    field.innerHTML = `<label>Mortgage Payment / Month</label>
      <div class="dollar"><input type="number" id="propertyPayment" min="0" placeholder="0"></div>`;
  } else if(status === 'rent'){
    field.innerHTML = `<label>Monthly Rent</label>
      <div class="dollar"><input type="number" id="propertyPayment" min="0" placeholder="0"></div>`;
  } else {
    field.innerHTML = `<label>Lease-to-Own Payment / Month</label>
      <div class="dollar"><input type="number" id="propertyPayment" min="0" placeholder="0"></div>`;
  }
}

// ═══════════════════════════════════════════════
// WEEKLY SCHEDULE CALENDAR v4
// ═══════════════════════════════════════════════
const DAYS = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

const LESSON_TYPES = {
  private: {label:'🐴 Private',      bg:'var(--gold-lt)',  border:'#DDB840'},
  group:   {label:'👥 Group',        bg:'var(--sage-lt)', border:'#88BB60'},
  semi:    {label:'👫 Semi-Private', bg:'#F0E4FA',        border:'#C090E8'},
  eval:    {label:'🔍 Eval',         bg:'var(--sky-lt)',  border:'#80B8E8'},
};
const STUDENT_TYPES = {
  lesson_horse: {label:'🐴 Lesson Horse', badge:'bg:#FFF3CD;color:#856404;border:#DDB840'},
  owner:        {label:'🏡 Owner/Boarder', badge:'bg:#D1ECF1;color:#0C5460;border:#80B8E8'},
};

// Each lesson: {id, arena, day, startH, startM, dur, type, instructor, students:[{name,horse,boarderHorse}]}
let schedLessons = [
  {id:1,  arena:'Main Arena',   day:'Mon', startH:9,  startM:0,  dur:60, type:'private', instructor:'', students:[{name:'',horse:''}]},
  {id:2,  arena:'Main Arena',   day:'Mon', startH:10, startM:0,  dur:60, type:'group', instructor:'', students:[{name:'',horse:''},{name:'',horse:''},{name:'',horse:''},{name:'',horse:''}]},
  {id:3,  arena:'Main Arena',   day:'Tue', startH:9,  startM:0,  dur:60, type:'private', instructor:'', students:[{name:'',horse:''}]},
  {id:4,  arena:'Main Arena',   day:'Wed', startH:9,  startM:0,  dur:60, type:'group', instructor:'', students:[{name:'',horse:''},{name:'',horse:''},{name:'',horse:''},{name:'',horse:''},{name:'',horse:''}]},
  {id:5,  arena:'Main Arena',   day:'Wed', startH:9,  startM:0,  dur:45, type:'semi',        instructor:'', students:[{name:'',horse:''},{name:'',horse:''}]},
  {id:6,  arena:'Main Arena',   day:'Thu', startH:9,  startM:0,  dur:60, type:'private', instructor:'', students:[{name:'',horse:''}]},
  {id:7,  arena:'Main Arena',   day:'Fri', startH:9,  startM:0,  dur:60, type:'group', instructor:'', students:[{name:'',horse:''},{name:'',horse:''},{name:'',horse:''},{name:'',horse:''}]},
  {id:8,  arena:'Outdoor Ring', day:'Tue', startH:10, startM:0,  dur:60, type:'group', instructor:'', students:[{name:'',horse:''},{name:'',horse:''},{name:'',horse:''},{name:'',horse:''}]},
  {id:9,  arena:'Outdoor Ring', day:'Thu', startH:10, startM:0,  dur:60, type:'semi',        instructor:'', students:[{name:'',horse:''},{name:'',horse:''}]},
  {id:10, arena:'Main Arena',   day:'Sat', startH:8,  startM:0,  dur:60, type:'private', instructor:'', students:[{name:'',horse:''}]},
  {id:11, arena:'Main Arena',   day:'Sat', startH:9,  startM:0,  dur:60, type:'group', instructor:'', students:[{name:'',horse:''},{name:'',horse:''},{name:'',horse:''},{name:'',horse:''},{name:'',horse:''},{name:'',horse:''}]},
  {id:12, arena:'Outdoor Ring', day:'Sat', startH:10, startM:0,  dur:60, type:'eval', instructor:'', students:[{name:'',horse:''}]},
];
let nextSchedId = 13;

function getSchedArenas(){
  if(arenas && arenas.length) return arenas.map(a=>a.name||`Arena ${a.id}`).filter(Boolean);
  return ['Main Arena'];
}
function getSchedInstructors(){
  if(instructors && instructors.length) return instructors.map(i=>i.name).filter(Boolean);
  return [];
}
function getSchedHorses(){
  const list = document.querySelectorAll('.horse-name-input');
  if(list.length) return [...list].map(el=>el.value).filter(Boolean);
  if(typeof horses !== 'undefined') return horses.map(h=>h.name).filter(Boolean);
  return ['Biscuit','Dakota','Rosie','Thunder'];
}

// ── Add / Edit lesson modal ──────────────────────
function schedAddLesson(day, startH){
  schedEditId = null;
  const arena = getSchedArenas()[0]||'';
  showSchedModal({id:null, arena, day: day||'Mon', startH: startH||9, startM:0, dur:60, type:'private', instructor:'', students:[{name:'',horse:''}]});
}
function schedEditLesson(id){
  const l = schedLessons.find(l=>l.id===id);
  if(l){schedEditId=id; showSchedModal({...l, students: l.students.map(s=>({...s}))});}
}
function schedDeleteLesson(id){
  schedLessons = schedLessons.filter(l=>l.id!==id);
  renderScheduleCalendar();
  syncSchedHiddenInputs();
}

let schedEditId = null;

function showSchedModal(l){
  const arenaList = getSchedArenas();
  const instrList = getSchedInstructors();
  const horseList = getSchedHorses();

  const arenaOpts = arenaList.map(a=>`<option value="${esc(a)}"${l.arena===a?' selected':''}>${esc(a)}</option>`).join('');
  const dayOpts   = DAYS.map(d=>`<option value="${d}"${l.day===d?' selected':''}>${d}</option>`).join('');
  const typeOpts  = Object.entries(LESSON_TYPES).map(([v,t])=>`<option value="${v}"${l.type===v?' selected':''}>${t.label}</option>`).join('');
  const instrOpts = `<option value="">— Unassigned —</option>`+instrList.map(n=>`<option value="${esc(n)}"${l.instructor===n?' selected':''}>${esc(n)}</option>`).join('');
  const durOpts   = [30,45,60,75,90,120].map(d=>`<option value="${d}"${l.dur===d?' selected':''}>${d} min</option>`).join('');
  const fmt2 = n=>String(n).padStart(2,'0');


  // Student rows — horse dropdown + "boarder's own horse" checkbox per student
  const studRows = (l.students||[{name:'',horse:'',boarderHorse:false}]).map((s,i)=>{
    const isBoarder = !!s.boarderHorse;
    const horseOpts = `<option value="">— School horse —</option>`+horseList.map(h=>`<option value="${esc(h)}"${s.horse===h?' selected':''}>${esc(h)}</option>`).join('');
    return `<tr id="smRow_${i}">
      <td style="padding:3px 4px;vertical-align:top"><input class="sm-stud-name" value="${esc(s.name)}" placeholder="Student name" style="width:100%;padding:4px 6px;font-size:11px;border:1px solid var(--border);border-radius:3px"></td>
      <td style="padding:3px 4px;vertical-align:top">
        <select class="sm-stud-horse" style="width:100%;padding:4px 6px;font-size:11px;border:1px solid var(--border);border-radius:3px;${isBoarder?'display:none':''}">${horseOpts}</select>
        ${isBoarder ? `<div style="font-size:11px;padding:4px 6px;background:#D1ECF1;color:#0C5460;border-radius:3px;border:1px solid #80B8E8">🏡 Boarder's own horse</div>` : ''}
        <label style="display:flex;align-items:center;gap:5px;margin-top:4px;font-size:10px;color:var(--muted);cursor:pointer">
          <input type="checkbox" class="sm-stud-boarder" ${isBoarder?'checked':''} onchange="smToggleBoarder(this)" style="margin:0">
          Boarder's own horse
        </label>
      </td>
      <td style="padding:3px 4px;width:28px;vertical-align:top"><button onclick="this.closest('tr').remove()" style="background:none;border:none;cursor:pointer;font-size:13px;color:var(--muted);line-height:1;margin-top:3px">✕</button></td>
    </tr>`;
  }).join('');

  let overlay = document.getElementById('schedModalOverlay');
  if(!overlay){
    overlay = document.createElement('div');
    overlay.id = 'schedModalOverlay';
    overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;display:flex;align-items:center;justify-content:center;padding:20px';
    overlay.onclick = e=>{if(e.target===overlay)closeSchedModal();};
    document.body.appendChild(overlay);
  }
  overlay.style.display = 'flex';
  overlay.innerHTML = `
    <div style="background:#FAF7F0;border-radius:8px;padding:22px 26px;width:480px;max-width:98vw;max-height:90vh;overflow-y:auto;box-shadow:0 8px 40px rgba(0,0,0,.2)">
      <div style="font-size:14px;font-weight:700;color:var(--brown);margin-bottom:16px">${schedEditId?'Edit':'Add'} Lesson</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">
        <div class="fg" style="margin:0;grid-column:1/-1"><label>Arena</label><select id="sm_arena" style="width:100%">${arenaOpts}</select></div>
        <div class="fg" style="margin:0"><label>Day</label><select id="sm_day" style="width:100%">${dayOpts}</select></div>
        <div class="fg" style="margin:0"><label>Start Time</label><input type="time" id="sm_time" value="${fmt2(l.startH)}:${fmt2(l.startM)}" style="width:100%"></div>
        <div class="fg" style="margin:0"><label>Duration</label><select id="sm_dur" style="width:100%">${durOpts}</select></div>
        <div class="fg" style="margin:0"><label>Lesson Type</label><select id="sm_type" style="width:100%">${typeOpts}</select></div>
        <div class="fg" style="margin:0;grid-column:1/-1"><label>Instructor</label><select id="sm_instr" style="width:100%">${instrOpts}</select></div>
      </div>
      <div style="font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:6px">Students & Horses</div>
      <div style="border:1px solid var(--border);border-radius:4px;overflow:hidden;margin-bottom:8px">
        <table style="width:100%;border-collapse:collapse">
          <thead><tr style="background:var(--cream);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--muted)">
            <th style="padding:5px 8px;text-align:left;width:45%">Student Name</th>
            <th style="padding:5px 8px;text-align:left">Horse</th>
            <th style="width:28px"></th>
          </tr></thead>
          <tbody id="smStudentRows">${studRows}</tbody>
        </table>
      </div>
      <button onclick="smAddStudent()" class="add-btn" style="margin-bottom:16px;font-size:11px">＋ Add Student</button>
      <div style="display:flex;gap:8px;justify-content:flex-end">
        ${schedEditId?`<button class="btn btn-s" onclick="schedDeleteLesson(${schedEditId});closeSchedModal()" style="font-size:11px;color:var(--rust);border-color:var(--rust);margin-right:auto">🗑 Delete</button>`:''}
        <button class="btn btn-s" onclick="closeSchedModal()" style="font-size:11px">Cancel</button>
        <button class="btn btn-p" onclick="saveSchedModal()" style="font-size:11px">Save Lesson</button>
      </div>
    </div>`;
}

function smToggleBoarder(cb){
  const td = cb.closest('td');
  const sel = td.querySelector('.sm-stud-horse');
  let badge = td.querySelector('.sm-boarder-badge');
  if(cb.checked){
    if(sel) sel.style.display = 'none';
    if(!badge){
      badge = document.createElement('div');
      badge.className = 'sm-boarder-badge';
      badge.style.cssText = 'font-size:11px;padding:4px 6px;background:#D1ECF1;color:#0C5460;border-radius:3px;border:1px solid #80B8E8;margin-bottom:2px';
      badge.textContent = '🏡 Boarder\'s own horse';
      td.insertBefore(badge, td.querySelector('label'));
    }
  } else {
    if(sel) sel.style.display = '';
    if(badge) badge.remove();
  }
}

function smAddStudent(){
  const horseList = getSchedHorses();
  const horseOpts = `<option value="">— School horse —</option>`+horseList.map(h=>`<option value="${esc(h)}">${esc(h)}</option>`).join('');
  const tbody = document.getElementById('smStudentRows');
  if(!tbody) return;
  const tr = document.createElement('tr');
  tr.innerHTML = `
    <td style="padding:3px 4px;vertical-align:top"><input class="sm-stud-name" value="" placeholder="Student name" style="width:100%;padding:4px 6px;font-size:11px;border:1px solid var(--border);border-radius:3px"></td>
    <td style="padding:3px 4px;vertical-align:top">
      <select class="sm-stud-horse" style="width:100%;padding:4px 6px;font-size:11px;border:1px solid var(--border);border-radius:3px">${horseOpts}</select>
      <label style="display:flex;align-items:center;gap:5px;margin-top:4px;font-size:10px;color:var(--muted);cursor:pointer">
        <input type="checkbox" class="sm-stud-boarder" onchange="smToggleBoarder(this)" style="margin:0">
        Boarder's own horse
      </label>
    </td>
    <td style="padding:3px 4px;width:28px;vertical-align:top"><button onclick="this.closest('tr').remove()" style="background:none;border:none;cursor:pointer;font-size:13px;color:var(--muted);line-height:1;margin-top:3px">✕</button></td>`;
  tbody.appendChild(tr);
}

function smRemoveStudent(i){
  const tbody = document.getElementById('smStudentRows');
  if(tbody && tbody.rows[i]) tbody.deleteRow(i);
}

function closeSchedModal(){
  const o = document.getElementById('schedModalOverlay');
  if(o) o.style.display='none';
}

function saveSchedModal(){
  const timeStr = document.getElementById('sm_time').value||'09:00';
  const [hh,mm] = timeStr.split(':').map(Number);

  // Collect students with boarderHorse flag
  const nameEls   = document.querySelectorAll('#smStudentRows .sm-stud-name');
  const horseEls  = document.querySelectorAll('#smStudentRows .sm-stud-horse');
  const boardEls  = document.querySelectorAll('#smStudentRows .sm-stud-boarder');
  const students = [];
  nameEls.forEach((el,i)=>{
    const isBoarder = boardEls[i]?.checked || false;
    students.push({
      name: el.value.trim(),
      horse: isBoarder ? '' : (horseEls[i]?.value||''),
      boarderHorse: isBoarder,
    });
  });

  const lesson = {
    arena:      document.getElementById('sm_arena').value,
    day:        document.getElementById('sm_day').value,
    startH:     hh, startM: mm,
    dur:        parseInt(document.getElementById('sm_dur').value),
    type:       document.getElementById('sm_type').value,
    instructor: document.getElementById('sm_instr').value,
    students:   students.length ? students : [{name:'',horse:'',boarderHorse:false}],
  };
  if(schedEditId){
    const idx = schedLessons.findIndex(l=>l.id===schedEditId);
    if(idx>=0) schedLessons[idx] = {...schedLessons[idx], ...lesson};
  } else {
    schedLessons.push({id:nextSchedId++, ...lesson});
  }
  closeSchedModal();
  renderScheduleCalendar();
  syncSchedHiddenInputs();
}

// ── Calendar render ──────────────────────────────
function renderScheduleCalendar(){
  const container = document.getElementById('schedCalendar');
  if(!container) return;

  const allArenas = [...new Set([...getSchedArenas(), ...schedLessons.map(l=>l.arena)])].filter(Boolean);
  if(!schedLessons.length){
    container.innerHTML = `<div style="text-align:center;padding:28px;color:var(--muted);font-size:13px">No lessons yet — click <strong>＋ Add Lesson</strong> to build your schedule.</div>`;
    renderSchedSummary(); return;
  }

  const dayStart = parseInt(document.getElementById('schedDayStart')?.value)||7;
  const dayEnd   = parseInt(document.getElementById('schedDayEnd')?.value)||20;

  let html = '';
  allArenas.forEach(arenaName=>{
    const arenaLessons = schedLessons.filter(l=>l.arena===arenaName);
    if(!arenaLessons.length) return;

    // Find max simultaneous lessons on any day/hour combo to size sub-columns
    let maxSimul = 1;
    DAYS.forEach(d=>{
      for(let h=dayStart;h<dayEnd;h++){
        const n = arenaLessons.filter(l=>l.day===d&&l.startH===h).length;
        if(n>maxSimul) maxSimul=n;
      }
    });
    // Each day column gets enough width for all sub-columns
    const subColW = 110; // px per simultaneous lesson slot
    const dayColW = maxSimul * subColW;
    const tableW  = 64 + DAYS.length * dayColW;

    html += `<div style="margin-bottom:22px">
      <div style="font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);padding:6px 10px;background:var(--cream);border:1px solid var(--border);border-radius:4px 4px 0 0;display:flex;justify-content:space-between">
        <span>🏟️ ${esc(arenaName)}</span>
        <span style="font-weight:400;font-size:10px">${arenaLessons.length} lesson${arenaLessons.length!==1?'s':''}/week</span>
      </div>
      <div style="overflow-x:auto">
      <table style="width:${tableW}px;min-width:100%;border-collapse:collapse;border:1px solid var(--border);border-top:none;table-layout:fixed">
        <colgroup>
          <col style="width:64px">
          ${DAYS.map(()=>`<col style="width:${dayColW}px">`).join('')}
        </colgroup>
        <thead><tr style="background:var(--cream)">
          <th style="padding:6px;font-size:10px;font-weight:700;text-transform:uppercase;color:var(--muted);border-right:1px solid var(--border);border-bottom:1px solid var(--border)"></th>`;
    DAYS.forEach(d=>{
      const cnt = arenaLessons.filter(l=>l.day===d).length;
      html+=`<th style="padding:6px 4px;font-size:11px;font-weight:700;text-transform:uppercase;color:var(--muted);border-right:1px solid var(--border);border-bottom:1px solid var(--border);text-align:center">
        ${d}${cnt?`<span style="display:inline-block;margin-left:5px;font-size:9px;color:var(--sage);font-weight:400">${cnt} lesson${cnt!==1?'s':''}</span>`:''}
      </th>`;
    });
    html+=`</tr></thead><tbody>`;

    for(let h=dayStart; h<dayEnd; h++){
      const label = h<12?`${h}:00 am`:h===12?'12:00 pm':`${h-12}:00 pm`;
      html+=`<tr><td style="padding:4px 6px;font-size:9px;color:var(--muted);text-align:right;vertical-align:top;border-right:1px solid var(--border);border-bottom:1px solid #EEE8DA;white-space:nowrap;background:var(--cream)">${label}</td>`;

      DAYS.forEach(d=>{
        const slot = arenaLessons.filter(l=>l.day===d && l.startH===h);
        // Always render sub-columns so simultaneous lessons sit side by side at same height
        if(slot.length === 0){
          html+=`<td onclick="schedAddLesson('${d}',${h})" title="Click to add a lesson at ${h<12?h+'am':h===12?'12pm':(h-12)+'pm'} on ${d}" style="border-right:1px solid var(--border);border-bottom:1px solid #EEE8DA;min-height:38px;padding:2px;cursor:pointer" onmouseover="this.style.background='#F5F0E8'" onmouseout="this.style.background=''">
            <div style="color:#C8BFA8;font-size:10px;text-align:center;padding-top:6px;pointer-events:none">＋</div>
          </td>`;
        } else {
          // Use a nested table for sub-columns so they're truly side-by-side at same row level
          html+=`<td style="border-right:1px solid var(--border);border-bottom:1px solid #EEE8DA;padding:2px;vertical-align:top">`;
          if(slot.length > 1){
            html+=`<table style="width:100%;border-collapse:collapse;table-layout:fixed"><tr>`;
            slot.forEach((l,i)=>{
              html+=`<td style="vertical-align:top;padding:1px;${i>0?'border-left:1px dashed #D4C9B0':''}">${renderLessonBlock(l)}</td>`;
            });
            html+=`</tr></table>`;
          } else {
            html += renderLessonBlock(slot[0]);
          }
          html+=`<div onclick="schedAddLesson('${d}',${h})" title="Add another lesson at this time" style="cursor:pointer;text-align:center;font-size:9px;color:#B8AFA0;padding:2px 0 1px;border-radius:2px" onmouseover="this.style.color='var(--sage)'" onmouseout="this.style.color='#B8AFA0'">＋ add</div>`;
          html+=`</td>`;
        }
      });
      html+=`</tr>`;
    }
    html+=`</tbody></table></div></div>`;
  });

  container.innerHTML = html;
  renderSchedSummary();
  renderSchedHorseHours();
}

function renderLessonBlock(l){
  const lt = LESSON_TYPES[l.type]||LESSON_TYPES.private;
  const students = l.students||[];
  const riders = students.length || 1;
  const boarderCount = students.filter(s=>s.boarderHorse).length;
  const startMin = l.startM>0?`:${String(l.startM).padStart(2,'0')}` : '';
  const instrTag = l.instructor?`<div style="font-size:9px;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(l.instructor)}</div>`:'';
  const boarderTag = boarderCount>0
    ? `<div style="font-size:9px;color:#0C5460;background:#D1ECF1;border-radius:2px;padding:1px 4px;display:inline-block;margin-top:1px">🏡 ${boarderCount} boarder${boarderCount>1?'s':''}</div>`
    : '';
  return `<div onclick="schedEditLesson(${l.id})" title="Click to edit" style="cursor:pointer;background:${lt.bg};border:1.5px solid ${lt.border};border-radius:3px;padding:4px 6px;margin-bottom:1px">
    <div style="font-weight:700;font-size:10px;color:var(--brown);white-space:nowrap">${l.startH}${startMin} · ${l.dur}m · ${riders}🧑</div>
    <div style="font-size:9px;color:var(--brown);opacity:.85">${lt.label}</div>
    ${boarderTag}
    ${instrTag}
  </div>`;
}

// ── Weekly summary bar ───────────────────────────
function renderSchedSummary(){
  const el = document.getElementById('schedSummary');
  if(!el) return;
  if(!schedLessons.length){el.innerHTML='';return;}
  const counts={private:0,group:0,semi:0,eval:0};
  let totalStudentSlots=0, boarderSlots=0;
  schedLessons.forEach(l=>{
    counts[l.type]=(counts[l.type]||0)+1;
    const studs = l.students||[];
    totalStudentSlots += studs.length||1;
    boarderSlots += studs.filter(s=>s.boarderHorse).length;
  });
  const schoolHorseSlots = totalStudentSlots - boarderSlots;
  el.innerHTML=`<div style="display:flex;flex-wrap:wrap;gap:10px;padding:10px 14px;background:var(--cream);border:1px solid var(--border);border-radius:4px;font-size:12px;align-items:center">
    <strong style="color:var(--brown)">${schedLessons.length} lessons/week</strong>
    <span style="color:var(--muted)">·</span>
    ${counts.private?`<span>🐴 <b>${counts.private}</b> private</span>`:''}
    ${counts.group  ?`<span>👥 <b>${counts.group}</b> group</span>`:''}
    ${counts.semi   ?`<span>👫 <b>${counts.semi}</b> semi-private</span>`:''}
    ${counts.eval   ?`<span>🔍 <b>${counts.eval}</b> eval</span>`:''}
    <span style="color:var(--muted)">·</span>
    ${schoolHorseSlots?`<span><b style="color:var(--brown)">${schoolHorseSlots}</b> on school horses</span>`:''}
    ${boarderSlots?`<span style="background:#D1ECF1;color:#0C5460;padding:2px 7px;border-radius:3px">🏡 <b>${boarderSlots}</b> on boarder's horse</span>`:''}
  </div>`;
  syncSchedHiddenInputs();
}

// ── Horse hours summary ──────────────────────────
function renderSchedHorseHours(){
  const el = document.getElementById('schedHorseHours');
  if(!el) return;

  // Tally hours per horse
  const horseTotals = {};
  schedLessons.forEach(l=>{
    const hrs = l.dur/60;
    (l.students||[]).forEach(s=>{
      if(s.horse){
        horseTotals[s.horse] = (horseTotals[s.horse]||0) + hrs;
      }
    });
  });

  const entries = Object.entries(horseTotals).sort((a,b)=>b[1]-a[1]);
  if(!entries.length){
    el.innerHTML=`<div style="font-size:11px;color:var(--muted);padding:8px 0">💡 Assign horses to students inside each lesson to see weekly horse hours here.</div>`;
    return;
  }

  // Count total lessons per horse too
  const horseLessons = {};
  schedLessons.forEach(l=>{
    (l.students||[]).forEach(s=>{
      if(s.horse) horseLessons[s.horse] = (horseLessons[s.horse]||0)+1;
    });
  });

  const maxHrs = entries[0][1];
  const rows = entries.map(([name,hrs])=>{
    const pct = Math.round((hrs/maxHrs)*100);
    const lessonCount = horseLessons[name]||0;
    return `<tr>
      <td style="padding:5px 10px;font-size:12px;font-weight:600;color:var(--brown);white-space:nowrap">${esc(name)}</td>
      <td style="padding:5px 10px;font-size:12px;color:var(--muted)">${lessonCount} lesson${lessonCount!==1?'s':''}</td>
      <td style="padding:5px 10px;width:200px">
        <div style="background:var(--border);border-radius:3px;height:8px;overflow:hidden">
          <div style="background:var(--sage);height:100%;width:${pct}%;border-radius:3px"></div>
        </div>
      </td>
      <td style="padding:5px 10px;font-size:12px;font-weight:700;color:var(--brown);text-align:right">${hrs%1===0?hrs:hrs.toFixed(1)} hrs/wk</td>
    </tr>`;
  }).join('');

  el.innerHTML=`<div style="border:1px solid var(--border);border-radius:4px;overflow:hidden">
    <div style="background:var(--cream);padding:7px 10px;font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border)">🐴 Horse Working Hours / Week</div>
    <table style="width:100%;border-collapse:collapse">
      <thead><tr style="font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);background:#FDFAF4">
        <th style="padding:4px 10px;text-align:left;border-bottom:1px solid var(--border)">Horse</th>
        <th style="padding:4px 10px;text-align:left;border-bottom:1px solid var(--border)">Lessons</th>
        <th style="padding:4px 10px;border-bottom:1px solid var(--border)"></th>
        <th style="padding:4px 10px;text-align:right;border-bottom:1px solid var(--border)">Hours</th>
      </tr></thead>
      <tbody>${rows}</tbody>
    </table>
  </div>`;
}

// ── Sync hidden inputs for downstream calc ───────
function syncSchedHiddenInputs(){
  const set=(id,v)=>{const el=document.getElementById(id);if(el)el.value=v;};
  const c={private:0,group:0,semi:0,eval:0};
  let maxR=1;
  schedLessons.forEach(l=>{c[l.type]=(c[l.type]||0)+1; const r=(l.students||[]).length||1; if(r>maxR)maxR=r;});
  set('wkPrivate',c.private); set('wkGroup',c.group); set('wkSemi',c.semi); set('wkEval',c.eval);
  set('groupRiders',maxR);
  const instrs=new Set(schedLessons.map(l=>l.instructor).filter(Boolean));
  set('numInstructors',Math.max(1,instrs.size));
}

init();
</script>
