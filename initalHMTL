          style="width:100%;padding:5px 8px;font-size:13px;text-align:center;border:1.5px solid ${roleInfo.border};background:${isSalary?'rgba(200,200,200,.3)':'rgba(255,255,255,.7)'};border-radius:3px;color:var(--brown)"
          oninput="updateInstructor(${ins.id},'hoursPerWeek',this.value)" ${isSalary?'placeholder="optional"':''}>
