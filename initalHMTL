function renderGoalCalendar(params){
  const wrap = document.getElementById('goalCalendarWrap');
  if(!wrap) return;
  const p          = params || getGoalParams();
  const mode       = p.mode || 'peak';
  const activeDays = p.activeDays || goalOpenDays;
  const numArenas  = p.numArenas || parseInt(document.getElementById('numArenas')?.value)||2;
  const arenas     = Array.from({length:numArenas}, (_,i)=>`Arena ${i+1}`);

  const fmt12 = h => { const ap=h>=12?'pm':'am'; const hh=h>12?h-12:(h===0?12:h); return `${hh}${ap}`; };

  // Shown hours = union of active-peak slots + any existing lessons
  const shownHours = [];
  for(let h=GOAL_HOURS_START; h<GOAL_HOURS_END; h++){
    if(activeDays.some(d=>isPeakSlot(d,h,mode,p)) || goalLessons.some(l=>l.hour===h&&activeDays.includes(l.day)))
      shownHours.push(h);
  }

  // Helper: lessons in a specific arena/day/hour
  const getSlot = (arena, day, h) => goalLessons.filter(l=>l.arena===arena&&l.day===day&&l.hour===h);
  // Helper: all lessons on a given day for a given arena
  const dayLessons = (arena, day) => goalLessons.filter(l=>l.arena===arena&&l.day===day);

  // ── Build one table per arena ──────────────────────────────────────────
  let html = '';
  arenas.forEach(arena => {
    html += `<div style="margin-bottom:24px">
      <div style="font-size:12px;font-weight:700;color:var(--brown);letter-spacing:.06em;text-transform:uppercase;margin-bottom:6px;padding:0 2px">🏟️ ${arena}</div>
      <table style="border-collapse:collapse;width:100%">
        <thead><tr>
          <th style="width:52px;padding:4px 6px;background:var(--cream);border:1px solid var(--border);font-size:10px;font-weight:700;text-transform:uppercase;color:var(--muted);position:sticky;left:0;z-index:2">Time</th>
          ${activeDays.map(d=>`<th style="min-width:115px;padding:5px 8px;background:var(--cream);border:1px solid var(--border);font-size:11px;font-weight:700;color:var(--brown);text-align:center">${d}</th>`).join('')}
        </tr></thead>
        <tbody>`;

    shownHours.forEach(h => {
      html += `<tr><td style="padding:3px 6px;border:1px solid var(--border);background:var(--cream);font-size:10px;font-weight:600;color:var(--muted);white-space:nowrap;vertical-align:middle;position:sticky;left:0">${fmt12(h)}</td>`;
      activeDays.forEach(day => {
        const active = isPeakSlot(day, h, mode, p);
        const slot   = getSlot(arena, day, h);
        const bg     = active ? '#FAFAF7' : '#F0EDE8';
        if(slot.length===0){
          html += `<td onclick="${active?`goalAddLessonAt('${day}',${h},'${arena}')`:''}"
            style="border:1px solid var(--border);padding:3px;min-width:115px;height:48px;vertical-align:middle;cursor:${active?'pointer':'default'};background:${bg}">
            ${active?'<div style="height:100%;display:flex;align-items:center;justify-content:center;color:#CCC;font-size:15px">+</div>':''}
          </td>`;
        } else {
          const blocks = slot.map(l=>{
            const ty=GOAL_TYPES[l.type]||GOAL_TYPES.group;
            return `<div onclick="goalEditLesson(${l.id})" style="cursor:pointer;background:${ty.bg};border:1.5px solid ${ty.border};border-radius:3px;padding:3px 6px;margin-bottom:2px">
              <div style="font-size:10px;font-weight:700;color:${ty.color}">${ty.label}</div>
              <div style="font-size:9px;color:var(--muted)">${l.riders||1} rider${(l.riders||1)>1?'s':''}</div>
            </div>`;
          }).join('');
          html += `<td style="border:1px solid var(--border);padding:3px;min-width:115px;vertical-align:top;background:${bg}">
            ${blocks}
            <div onclick="goalAddLessonAt('${day}',${h},'${arena}')" style="text-align:center;font-size:9px;color:#BBB;cursor:pointer;padding:1px">+ add</div>
          </td>`;
        }
      });
      html += '</tr>';
    });

    // ── Daily totals footer row ─────────────────────────────────────────
    html += `<tr style="background:#F5F2EB">
      <td style="padding:5px 6px;border:1px solid var(--border);font-size:10px;font-weight:700;color:var(--brown);white-space:nowrap;position:sticky;left:0;background:#F5F2EB">Totals</td>`;
    activeDays.forEach(day => {
      const dl = dayLessons(arena, day);
      const lessonCount = dl.length;
      const studentCount = dl.reduce((s,l)=>s+(l.riders||1),0);
      // Concurrent instructor slots this day
      const concurrentSlots = {};
      dl.forEach(l=>{ concurrentSlots[l.hour]=(concurrentSlots[l.hour]||0)+1; });
      const instrSlots = Object.values(concurrentSlots).reduce((s,v)=>s+v,0);
      const instrHrs = instrSlots * ((parseInt(document.getElementById('goalLessonDur')?.value)||60)/60);
      if(lessonCount===0){
        html += `<td style="border:1px solid var(--border);padding:5px 6px;text-align:center;font-size:10px;color:var(--muted)">—</td>`;
      } else {
        html += `<td style="border:1px solid var(--border);padding:5px 6px;text-align:center">
          <div style="font-size:11px;font-weight:700;color:var(--brown)">${lessonCount} lesson${lessonCount>1?'s':''}</div>
          <div style="font-size:10px;color:var(--muted)">${studentCount} students</div>
          <div style="font-size:10px;color:#5A4A30">${instrHrs.toFixed(1)} instr hrs</div>
        </td>`;
      }
    });
    html += '</tr></tbody></table></div>';
  });

  // ── Cross-arena daily totals (horses+instructors per day) ──────────────
  html += `<div style="margin-top:4px;margin-bottom:8px">
    <div style="font-size:12px;font-weight:700;color:var(--brown);letter-spacing:.06em;text-transform:uppercase;margin-bottom:6px">📊 Daily Totals — All Arenas Combined</div>
    <table style="border-collapse:collapse;width:100%">
      <thead><tr>
        <th style="width:130px;padding:5px 8px;background:var(--cream);border:1px solid var(--border);font-size:10px;font-weight:700;text-transform:uppercase;color:var(--muted)"></th>
        ${activeDays.map(d=>`<th style="padding:5px 8px;background:var(--cream);border:1px solid var(--border);font-size:11px;font-weight:700;color:var(--brown);text-align:center">${d}</th>`).join('')}
      </tr></thead>
      <tbody>`;

  const durH = (parseInt(document.getElementById('goalLessonDur')?.value)||60)/60;
  const horseMaxDay  = parseInt(document.getElementById('horseMaxDay')?.value)||2;
  const maxLessonsPerHorseDay = Math.max(1, Math.floor(horseMaxDay/durH));

  // Row: lessons/day
  html += `<tr><td style="padding:4px 8px;border:1px solid var(--border);background:var(--cream);font-size:10px;font-weight:600;color:var(--muted)">Total Lessons</td>`;
  activeDays.forEach(day=>{
    const n = goalLessons.filter(l=>l.day===day).length;
    html += `<td style="border:1px solid var(--border);padding:4px 8px;text-align:center;font-size:11px;font-weight:700;color:var(--brown)">${n||'—'}</td>`;
  });
  html += '</tr>';

  // Row: students/day
  html += `<tr><td style="padding:4px 8px;border:1px solid var(--border);background:var(--cream);font-size:10px;font-weight:600;color:var(--muted)">Students Taught</td>`;
  activeDays.forEach(day=>{
    const s = goalLessons.filter(l=>l.day===day).reduce((sum,l)=>sum+(l.riders||1),0);
    html += `<td style="border:1px solid var(--border);padding:4px 8px;text-align:center;font-size:11px;font-weight:700;color:var(--brown)">${s||'—'}</td>`;
  });
  html += '</tr>';

  // Row: instructors needed (max concurrent lessons that day)
  html += `<tr><td style="padding:4px 8px;border:1px solid var(--border);background:var(--cream);font-size:10px;font-weight:600;color:var(--muted)">Instructors Needed</td>`;
  activeDays.forEach(day=>{
    const slots = {};
    goalLessons.filter(l=>l.day===day).forEach(l=>{ slots[l.hour]=(slots[l.hour]||0)+1; });
    const maxCon = Math.max(0, ...Object.values(slots));
    html += `<td style="border:1px solid var(--border);padding:4px 8px;text-align:center;font-size:11px;font-weight:700;color:var(--brown)">${maxCon||'—'}</td>`;
  });
  html += '</tr>';

  // Row: instructor hours/day
  html += `<tr><td style="padding:4px 8px;border:1px solid var(--border);background:var(--cream);font-size:10px;font-weight:600;color:var(--muted)">Instructor Hours</td>`;
  activeDays.forEach(day=>{
    const n = goalLessons.filter(l=>l.day===day).length;
    const h = (n * durH).toFixed(1);
    html += `<td style="border:1px solid var(--border);padding:4px 8px;text-align:center;font-size:11px;color:var(--muted)">${n?h+'h':'—'}</td>`;
  });
  html += '</tr>';

  // Row: horses needed that day
  html += `<tr><td style="padding:4px 8px;border:1px solid var(--border);background:var(--cream);font-size:10px;font-weight:600;color:var(--muted)">🐴 Horses Needed</td>`;
  activeDays.forEach(day=>{
    // Peak concurrent riders = horses needed at peak
    const riderSlots = {};
    goalLessons.filter(l=>l.day===day&&l.type!=='eval').forEach(l=>{
      riderSlots[l.hour]=(riderSlots[l.hour]||0)+(l.riders||1);
    });
    const peakRiders = Math.max(0, ...Object.values(riderSlots));
    // Daily work limit
    const totalRiderSlots = goalLessons.filter(l=>l.day===day&&l.type!=='eval').reduce((s,l)=>s+(l.riders||1),0);
    const byDailyLimit = Math.ceil(totalRiderSlots / maxLessonsPerHorseDay);
    const needed = Math.max(peakRiders, byDailyLimit);
    html += `<td style="border:1px solid var(--border);padding:4px 8px;text-align:center;font-size:11px;font-weight:700;color:#2A5C1A">${needed||'—'}</td>`;
  });
  html += '</tr>';

  html += '</tbody></table></div>';

  wrap.innerHTML = html;
  renderGoalResources();
}

function renderGoalResources(){
  const el = document.getElementById('goalResourceBody');
  if(!el||!goalLessons.length) return;
  const p            = getGoalParams();
  const instrRate    = p.instrRate;
  const durH         = (p.lessonDur||60)/60;
  const total        = goalLessons.length;
  const horseMaxWeek = parseInt(document.getElementById('horseMaxWeek')?.value)||10;
  const horseMaxDay  = parseInt(document.getElementById('horseMaxDay')?.value)||2;
  const horseDaysOff = parseInt(document.getElementById('horseDaysOff')?.value)||1;
  const workDaysPerWeek = Math.max(1, goalOpenDays.length - horseDaysOff);

  const byType = {};
  Object.keys(GOAL_TYPES).forEach(k=>byType[k]=0);
  goalLessons.forEach(l=>{ byType[l.type]=(byType[l.type]||0)+1; });

  // Instructors = max concurrent lessons at any single timeslot
  const instrHrsPerWeek = total * durH;
  const slotCounts = {};
  goalLessons.forEach(l=>{ const k=`${l.day}_${l.hour}`; slotCounts[k]=(slotCounts[k]||0)+1; });
  const maxConcurrent = Math.max(...Object.values(slotCounts),1);

  // Horse need — three limits, take the maximum:
  // 1. Peak concurrent riders (must have enough horses in the ring at once)
  const riderSlotsPerTime = {};
  goalLessons.filter(l=>l.type!=='eval').forEach(l=>{
    const k=`${l.day}_${l.hour}`; riderSlotsPerTime[k]=(riderSlotsPerTime[k]||0)+(l.riders||1);
  });
  const peakConcurrentRiders = Math.max(...Object.values(riderSlotsPerTime), 0);

  // 2. Daily limit: horses needed = total riders that day ÷ max lessons/horse/day
  const horseMaxLessonsDay  = Math.max(1, Math.floor(horseMaxDay / durH));
  const ridersByDay = {};
  goalLessons.filter(l=>l.type!=='eval').forEach(l=>{
    ridersByDay[l.day] = (ridersByDay[l.day]||0) + (l.riders||1);
  });
  const maxByDailyLimit = Math.max(...Object.values(ridersByDay).map(r=>Math.ceil(r/horseMaxLessonsDay)), 0);

  // 3. Weekly limit: total rider-lessons ÷ max lessons/horse/week
  const horseMaxLessonsWeek = Math.max(1, Math.floor(horseMaxWeek / durH));
  const totalHorseLessons   = goalLessons.filter(l=>l.type!=='eval').reduce((s,l)=>s+(l.riders||1),0);
  const horsesByWeeklyLimit = Math.ceil(totalHorseLessons / horseMaxLessonsWeek);
  // Days-off constraint: each horse only works workDaysPerWeek days,
  // so if peak daily riders > horseMaxLessonsDay, need extra horses for rotation
  const horsesForDaysOff = horseDaysOff > 0
    ? Math.ceil(Math.max(...Object.values(riderSlotsPerTime), 0) * (goalOpenDays.length / workDaysPerWeek))
    : 0;

  // Take the binding constraint
  const horsesNeeded = Math.max(peakConcurrentRiders, maxByDailyLimit, horsesByWeeklyLimit, horsesForDaysOff);
  const bindingReason = horsesNeeded === peakConcurrentRiders ? 'peak concurrent riders'
    : horsesNeeded === maxByDailyLimit ? `daily limit (${horseMaxDay} hrs/day)`
    : horsesNeeded === horsesForDaysOff ? `days-off rotation (${horseDaysOff} day${horseDaysOff!==1?'s':''} off/week)`
    : `weekly limit (${horseMaxWeek} hrs/week)`;

  const avgHorseHrsWeek = totalHorseLessons > 0 && horsesNeeded > 0
    ? ((totalHorseLessons * durH) / horsesNeeded).toFixed(1) : '0';

  const totalRiders      = goalLessons.reduce((s,l)=>s+(l.riders||1),0);
  const instrCostPer4Wks = instrHrsPerWeek * instrRate * 4;

  // Welfare status color
  const avgH = parseFloat(avgHorseHrsWeek);
  const welfareOk = avgH <= horseMaxWeek * 0.85;
  const welfareColor = welfareOk ? '#2A5C1A' : '#A0380A';
  const welfareLabel = welfareOk ? '✅ Within limits' : '⚠️ Near limit';

  const ks = 'flex:1;min-width:145px;background:var(--cream);border:1px solid var(--border);border-radius:6px;padding:12px 16px;text-align:center';
  el.innerHTML = `
    <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:14px">
      <div style="${ks}">
        <div style="font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px">Lessons / Week</div>
        <div style="font-size:26px;font-weight:700;color:var(--brown)">${total}</div>
      </div>
      <div style="${ks}">
        <div style="font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px">Instructors Needed</div>
        <div style="font-size:26px;font-weight:700;color:var(--brown)">${maxConcurrent}</div>
        <div style="font-size:10px;color:var(--muted)">${instrHrsPerWeek.toFixed(0)} hrs/wk total</div>
      </div>
      <div style="${ks};border-color:#88BB60">
        <div style="font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px">🐴 Horses Needed</div>
        <div style="font-size:26px;font-weight:700;color:var(--brown)">${horsesNeeded}</div>
        <div style="font-size:10px;color:var(--muted)">limited by ${bindingReason}</div>
      </div>
      <div style="${ks}">
        <div style="font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px">Avg Horse hrs/Week</div>
        <div style="font-size:26px;font-weight:700;color:${welfareColor}">${avgHorseHrsWeek}</div>
        <div style="font-size:10px;color:${welfareColor}">${welfareLabel}</div>
      </div>
      <div style="${ks}">
        <div style="font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px">Rider-Slots / Week</div>
        <div style="font-size:26px;font-weight:700;color:var(--brown)">${totalRiders}</div>
      </div>
      <div style="${ks}">
        <div style="font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px">Instructor Cost / 4 Wks</div>
        <div style="font-size:26px;font-weight:700;color:var(--rust)">$${fmt(instrCostPer4Wks)}</div>
        <div style="font-size:10px;color:var(--muted)">@ $${instrRate}/hr</div>
      </div>
    </div>
    <div style="background:var(--gold-lt);border:1px solid #DDB840;border-radius:5px;padding:9px 12px;font-size:11px;color:#5A4000;margin-bottom:10px;line-height:1.6">
      <strong>Horse math:</strong> ${peakConcurrentRiders} for peak concurrent riders · ${maxByDailyLimit} for daily limit (${horseMaxDay} hrs/day) · ${horsesByWeeklyLimit} for weekly limit (${horseMaxWeek} hrs/week) · ${horsesForDaysOff} for days-off rotation (${horseDaysOff} day off/week) → <strong>${horsesNeeded} horses total (binding: ${bindingReason})</strong>
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:8px;font-size:12px">
      ${Object.entries(GOAL_TYPES).map(([k,ty])=>byType[k]?`<span style="background:${ty.bg};border:1px solid ${ty.border};color:${ty.color};border-radius:3px;padding:3px 10px">${ty.label}: <strong>${byType[k]}</strong>/wk</span>`:'').join('')}
    </div>
    <p style="font-size:11px;color:var(--muted);margin:10px 0 0">All figures update live as you edit the calendar. Horse count reflects the most restrictive of 3 constraints: peak concurrent riders, daily welfare limit, and weekly welfare limit.</p>`;
}

