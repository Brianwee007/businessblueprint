    renderScheduleOutput(text, p, {horseMaxWeek, horseMaxDay, horseDaysOff});
    buildComparison(text, {instrRate:p.instrRate, targetStudents: maxSimult*3, t1, t2, t3, nums});

  } catch(err){
    document.getElementById('scheduleLoading').style.display = 'none';
