function buildComparison(scheduleText, params){
  const nums = params.nums;
  // Current state
  const wkPrivate=nums.wkPrivate,wkGroup=nums.wkGroup,wkSemi=nums.wkSemi,wkEval=nums.wkEval;
  const durFactor=nums.lessonDur/60;
  const curWeeklyRev = wkPrivate*nums.pricePrivate + wkGroup*nums.priceGroup + wkSemi*nums.priceSemi + wkEval*nums.priceEval;
  const curMonthly = curWeeklyRev * 4;
  const curInstrHrs = (wkPrivate+wkGroup+wkSemi+wkEval)*durFactor;
  const curInstrCost = curInstrHrs * 4.3 * nums.instrRate;
  const curNet = curMonthly - curInstrCost;

  // Goal state — extract from AI text
  const extractNum = (pattern) => {
    const m = scheduleText.match(pattern);
    return m ? parseFloat(m[1].replace(/[,$]/g,'')) : null;
  };
  const goalMonthly = extractNum(/monthly revenue.*?\$([0-9,]+)/i) || params.targetStudents * params.t1 * 0.7;
  const goalInstrCost = extractNum(/instructor cost.*?month.*?\$([0-9,]+)/i) || goalMonthly * 0.25;
  const goalNet = goalMonthly - goalInstrCost;

  goalRevenue = goalMonthly;

  const rows = [
    {label:'Active Students', cur: nums.totalStudents, goal: params.targetStudents, isCount:true},
    {label:'Monthly Lesson Revenue', cur: curMonthly, goal: goalMonthly},
    {label:'Instructor Cost / Month', cur: curInstrCost, goal: goalInstrCost, isExpense:true},
    {label:'Net Before Overhead', cur: curNet, goal: goalNet},
    {label:'Annual Revenue', cur: curMonthly*12, goal: goalMonthly*12},
  ];

  let html = `
    <div class="kpis">
      <div class="kpi hi"><div class="kl">Goal Monthly Revenue</div><div class="kv">$${fmt(goalMonthly)}</div><div class="ks">at ${params.targetStudents} students</div></div>
      <div class="kpi ${curMonthly > 0 ? 'mid-c' : 'lo'}"><div class="kl">Current Monthly Revenue</div><div class="kv">$${fmt(curMonthly)}</div><div class="ks">today</div></div>
      <div class="kpi hi"><div class="kl">Revenue Uplift</div><div class="kv">+$${fmt(goalMonthly-curMonthly)}</div><div class="ks">/month</div></div>
      <div class="kpi info"><div class="kl">Annual Difference</div><div class="kv">+$${fmt((goalMonthly-curMonthly)*12)}</div><div class="ks">/year</div></div>
    </div>
    <div class="card">
      <div class="card-h"><span class="ico">⚖️</span><span class="ttl">Current vs. Optimized — Side by Side</span></div>
      <div class="card-b">
        <table class="cmp">
          <thead><tr><th>Metric</th><th class="r" style="color:var(--rust)">Current</th><th class="r" style="color:var(--sage)">Optimized Goal</th><th class="r">Difference</th></tr></thead>
          <tbody>`;

  rows.forEach(r => {
    const diff = r.goal - r.cur;
    const good = r.isExpense ? diff < 0 : diff > 0;
    const cls = diff === 0 ? '' : good ? 'pos' : 'neg';
    const sign = diff > 0 ? '+' : '';
    html += `<tr>
      <td>${r.label}</td>
      <td class="r">${r.isCount ? r.cur : '$'+fmt(r.cur)}</td>
      <td class="r">${r.isCount ? r.goal : '$'+fmt(r.goal)}</td>
      <td class="r ${cls}">${sign}${r.isCount ? Math.round(diff) : '$'+fmt(diff)}</td>
    </tr>`;
  });

  html += `</tbody><tr class="tot"><td>Monthly Net Profit (before fixed costs)</td><td class="r">$${fmt(curNet)}</td><td class="r">$${fmt(goalNet)}</td><td class="r ${goalNet>curNet?'pos':'neg'}">${goalNet>curNet?'+':''}$${fmt(goalNet-curNet)}</td></tr></table>
      </div>
    </div>`;

  // Key insight
  html += I('ig','🎯',`<strong>The single biggest lever:</strong> Moving ${nums.totalStudents} existing students to memberships — even at today's lesson volume — converts inconsistent per-lesson income into guaranteed recurring revenue. The schedule optimization then layers on top of that foundation.`);

  if(scheduleText.includes('4') || scheduleText.includes('8pm')){
    const fourEightMatch = scheduleText.match(/\$([0-9,]+).*?month/i);
    if(fourEightMatch) html += I('iw','⏰',`<strong>The 4–8pm window insight:</strong> Peak evening hours are often the most underutilized time in a riding school. The schedule above shows what consistent, optimized use of just those 4 hours per weeknight could generate.`);
  }

  document.getElementById('comparisonOutput').innerHTML = html;
}

