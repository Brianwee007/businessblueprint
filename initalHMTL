function initGoalDayToggles(){
  const wrap = document.getElementById('goalDayToggles');
  if(!wrap) return;
  wrap.innerHTML = GOAL_ALL_DAYS.map(d => {
    const open = goalOpenDays.includes(d);
    return `<button id="dayToggle_${d}" onclick="goalToggleDay('${d}')" style="padding:7px 16px;border-radius:4px;font-size:12px;font-weight:700;cursor:pointer;border:2px solid;background:${open?'var(--brown)':'#E8E4DC'};color:${open?'#fff':'var(--muted)'};border-color:${open?'var(--brown)':'#CCC'}">${d}</button>`;
  }).join('');
  // Peak hours selects — update summary on change
  ['peakWdayStart','peakWdayEnd','peakWkendStart','peakWkendEnd'].forEach(id=>{
    const el = document.getElementById(id);
    if(el) el.onchange = () => { updatePeakSummary(); if(goalLessons.length) renderGoalCalendar(); };
  });
  updatePeakSummary();
