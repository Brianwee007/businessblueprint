function goalToggleDay(d){
  if(goalOpenDays.includes(d)){
    if(goalOpenDays.length <= 1) return;
    goalOpenDays = goalOpenDays.filter(x=>x!==d);
  } else {
    goalOpenDays = GOAL_ALL_DAYS.filter(x=>goalOpenDays.includes(x)||x===d);
  }
  initGoalDayToggles();
  if(goalLessons.length) renderGoalCalendar();
}

function getGoalParams(){
  const mode          = document.getElementById('scheduleMode')?.value || 'peak';
  const numArenas     = parseInt(document.getElementById('numArenas')?.value)||2;
  const instrRate     = parseFloat(document.getElementById('goalInstrRate')?.value)||35;
  const lessonDur     = parseInt(document.getElementById('goalLessonDur')?.value)||60;
  const peakWdayStart = parseInt(document.getElementById('peakWdayStart')?.value)||16;
  const peakWdayEnd   = parseInt(document.getElementById('peakWdayEnd')?.value)||20;
  const peakWkendStart= parseInt(document.getElementById('peakWkendStart')?.value)||8;
  const peakWkendEnd  = parseInt(document.getElementById('peakWkendEnd')?.value)||20;
  return { mode, numArenas, instrRate, lessonDur,
    activeDays: [...goalOpenDays], hStart: GOAL_HOURS_START, hEnd: GOAL_HOURS_END,
    peakWdayStart, peakWdayEnd, peakWkendStart, peakWkendEnd };
}

function goalToggleScheduleMode(){
  const mode = document.getElementById('scheduleMode')?.value;
  const ed   = document.getElementById('peakHoursEditor');
  if(ed) ed.style.display = mode==='peak' ? '' : 'none';
  updatePeakSummary();
  if(goalLessons.length) renderGoalCalendar();
}

function updatePeakSummary(){
  const el = document.getElementById('peakHoursSummary');
  if(!el) return;
  const p = getGoalParams();
  const fmt12s = h => { const ap=h>=12?'pm':'am'; const hh=h>12?h-12:(h===0?12:h); return hh+ap; };
  el.textContent = `Mon–Fri: ${fmt12s(p.peakWdayStart)} – ${fmt12s(p.peakWdayEnd)}   ·   Sat–Sun: ${fmt12s(p.peakWkendStart)} – ${fmt12s(p.peakWkendEnd)}`;
}

function isPeakSlot(day, hour, mode, p){
  if(mode !== 'peak') return true;
  const params = p || getGoalParams();
  const isWeekend = day==='Sat'||day==='Sun';
  if(isWeekend) return hour >= params.peakWkendStart && hour < params.peakWkendEnd;
  return hour >= params.peakWdayStart && hour < params.peakWdayEnd;
}

async function buildGoalSchedule(){
  const p            = getGoalParams();
  const maxSimult    = parseInt(document.getElementById('maxSimult').value)||8;
  const newPerMonth  = parseInt(document.getElementById('newPerMonth').value)||6;
  const groupSize    = parseInt(document.getElementById('goalGroupSize').value)||5;
  const horseMaxWeek = parseInt(document.getElementById('horseMaxWeek').value)||10;
  const horseMaxDay  = parseInt(document.getElementById('horseMaxDay').value)||2;
  const horseDaysOff = parseInt(document.getElementById('horseDaysOff').value)||1;
  const nums         = getInputNums();
  const t1 = parseFloat(document.getElementById('t1Price').value)||300;
  const t2 = parseFloat(document.getElementById('t2Price').value)||600;
  const t3 = parseFloat(document.getElementById('t3Price').value)||900;

  const durH = (p.lessonDur||60)/60;
  const workDaysPerWeek = Math.max(1, p.activeDays.length - horseDaysOff);
  const horseMaxLessonsDay  = Math.max(1, Math.floor(horseMaxDay / durH));
  const horseMaxLessonsWeek = Math.max(1, Math.floor(horseMaxWeek / durH));

  // Build peak description from user inputs
  const peakWdayStart  = parseInt(document.getElementById('peakWdayStart')?.value)||16;
  const peakWdayEnd    = parseInt(document.getElementById('peakWdayEnd')?.value)||20;
  const peakWkendStart = parseInt(document.getElementById('peakWkendStart')?.value)||8;
  const peakWkendEnd   = parseInt(document.getElementById('peakWkendEnd')?.value)||20;
  const fmt12s = h => { const ap=h>=12?'pm':'am'; const hh=h>12?h-12:(h===0?12:h); return hh+ap; };
  const peakDesc = p.mode==='peak'
    ? `Mon-Fri ${fmt12s(peakWdayStart)}-${fmt12s(peakWdayEnd)}, Sat-Sun ${fmt12s(peakWkendStart)}-${fmt12s(peakWkendEnd)}`
    : '7am-8pm all open days';
  const activeHoursDesc = p.mode==='peak'
    ? `weekdays hours ${peakWdayStart}-${peakWdayEnd-1}, weekends hours ${peakWkendStart}-${peakWkendEnd-1}`
    : 'hours 7-19';

  document.getElementById('scheduleLoading').style.display = 'block';
  document.getElementById('scheduleLoading').innerHTML = `<div class="ai-loading"><div class="spinner"></div><span>Building Goal Schedule — ${p.numArenas} arena(s), ${p.activeDays.join('/')}, horse welfare limits applied…</span></div>`;
  document.getElementById('scheduleOutput').innerHTML = '';

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514', max_tokens:6000,
        messages:[{role:'user', content:`You are a riding school consultant building a MAXIMIZED goal schedule constrained by horse welfare limits.

HARD CONSTRAINTS:
- Open days: ${p.activeDays.join(', ')}
- Scheduling window: ${peakDesc}
- Active hours: ${activeHoursDesc}
- Arenas: ${p.numArenas} (named "Arena 1" through "Arena ${p.numArenas}")
- Max simultaneous riders across ALL arenas at once: ${maxSimult}
- Lesson duration: ${p.lessonDur} min (${durH.toFixed(1)} hrs)
- Target group size: ${groupSize} riders
- New students/month needing eval+intro: ${newPerMonth}

HORSE WELFARE (hard limits):
- Max hrs/horse/WEEK: ${horseMaxWeek} → max ${horseMaxLessonsWeek} lessons/week per horse
- Max hrs/horse/DAY: ${horseMaxDay} → max ${horseMaxLessonsDay} lessons/day per horse
- Days off/week per horse: ${horseDaysOff} → horse works max ${workDaysPerWeek} days/week
- Calculate minimum horses needed and include the math

GOAL: Maximize group lessons (${groupSize} riders each = most revenue/instructor hour). Fill every active slot. Multiple arenas = simultaneous lessons at same hour, one entry per arena.

RESPOND IN EXACTLY THIS FORMAT:

SCHEDULE_SUMMARY: [2 sentences]

WEEKLY_STATS:
- Total lessons/week: [n]
- Group lessons/week: [n]
- Private lessons/week: [n]
- Intro/eval slots/week: [n]
- Instructors needed: [n]
- Total instructor hours/week: [n]
- Horses needed: [n]
- Total horse hours/week: [n]
- Avg horse hours/week: [n]
- Estimated revenue every 4 weeks: $[n]

HORSE_MATH:
[3-4 sentences with specific numbers: peak concurrent riders needed, daily limit constraint, weekly limit constraint, days-off constraint, final horse count]

RECOMMENDATIONS:
1. [action]
2. [action]
3. [action]

CALENDAR_DATA:
[ONLY a raw JSON array — no markdown fences, no explanation, just the array.
Each object: {"day":"Mon","hour":16,"duration":${p.lessonDur},"type":"group","riders":${groupSize},"arena":"Arena 1"}
- day: from ${p.activeDays.join(', ')} only
- hour: integer — ${activeHoursDesc}
- type: "group" (use 70%+), "private", "semi", "eval", "intro"
- riders: group=${groupSize}, semi=2, private/eval/intro=1
- arena: "Arena 1" through "Arena ${p.numArenas}"
For ${p.numArenas} arenas: output one lesson per arena per active hour (different arenas may run simultaneously). Fill all active slots.]`}]})
    });
    const data = await resp.json();
    if(data.error) throw new Error(data.error.message);
    const text = data.content.map(c=>c.text||'').join('');

    const calMatch = text.match(/CALENDAR_DATA:\s*([\s\S]*)$/i);
    let parsed = [];
    if(calMatch){
      try { parsed = JSON.parse(calMatch[1].trim().replace(/```[\w]*\n?|```/g,'')); }
      catch(e){ console.warn('Goal calendar parse error', e); }
    }
    goalLessons = parsed.map(l=>({...l, id:goalNextId++}));

    document.getElementById('scheduleLoading').style.display = 'none';
