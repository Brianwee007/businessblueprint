<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Riding School Revenue Optimizer</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --brown:#2C1A0E; --mid:#5C3320; --tan:#B8862A; --tan-lt:#F5EDD0;
  --cream:#FAF7F0; --white:#FFFEF9; --border:#DDD0B0; --muted:#8A7558;
  --sage:#3D5E2C; --sage-lt:#E0EDD4; --rust:#8C2510; --rust-lt:#FAEAE0;
  --sky:#1A4A80; --sky-lt:#DCE9F8; --gold:#9A7800; --gold-lt:#FDF5CC;
  --ink:#1A1008;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--ink);font-size:14px;line-height:1.6;min-height:100vh}

/* HEADER */
.hdr{background:var(--brown);padding:0;position:sticky;top:0;z-index:200;box-shadow:0 2px 12px rgba(0,0,0,.35)}
.hdr-inner{max-width:1100px;margin:0 auto;padding:0 20px;display:flex;align-items:center;gap:0}
.logo{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:#FAF7F0;padding:13px 0;white-space:nowrap}
.logo em{color:var(--tan);font-style:normal}
.phase-track{display:flex;flex:1;margin-left:28px;overflow-x:auto}
.pt{padding:14px 12px;font-size:10px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.3);border-bottom:2px solid transparent;cursor:pointer;transition:all .2s;white-space:nowrap;border:none;background:none;font-family:'DM Sans',sans-serif}
.pt:hover{color:rgba(255,255,255,.6)}
.pt.active{color:var(--tan);border-bottom:2px solid var(--tan)}
.pt.done{color:rgba(255,255,255,.5)}
.prog-bar{height:3px;background:rgba(255,255,255,.08)}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--tan),#D4A840);transition:width .4s ease}

/* LAYOUT */
.app{max-width:900px;margin:0 auto;padding:28px 20px 60px}
.phase{display:none}
.phase.on{display:block;animation:fadeUp .3s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

/* PHASE HEADERS */
.ph{margin-bottom:24px;padding-bottom:18px;border-bottom:2px solid var(--border)}
.ph-num{font-size:11px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--tan);margin-bottom:6px}
.ph-title{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:600;line-height:1.2;color:var(--brown)}
.ph-sub{font-size:13px;color:var(--muted);margin-top:5px;max-width:620px}

/* CARDS */
.card{background:var(--white);border:1.5px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:16px}
.card-h{background:var(--mid);color:#FAF7F0;padding:10px 16px;display:flex;align-items:center;gap:8px}
.card-h .ico{font-size:16px}.card-h .ttl{font-family:'Cormorant Garamond',serif;font-size:15px;font-weight:600}
.card-h .sub{margin-left:auto;font-size:10px;color:rgba(255,255,255,.5);letter-spacing:.08em}
.card-b{padding:16px}

/* FORM */
.frow{display:flex;flex-wrap:wrap;gap:14px;margin-bottom:14px}
.fg{display:flex;flex-direction:column;gap:5px;flex:1;min-width:160px}
.fg.full{flex:1 0 100%}
.fg.w2{flex:0 0 calc(50% - 7px)}
.fg.w3{flex:0 0 calc(33% - 10px)}
label{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
input,select,textarea{padding:8px 11px;border:1.5px solid var(--border);background:var(--tan-lt);font-family:'DM Sans',sans-serif;font-size:13px;color:var(--brown);border-radius:3px;transition:border-color .15s;width:100%}
input:focus,select:focus,textarea:focus{outline:none;border-color:var(--tan);background:var(--white)}
input[type=number]{text-align:right}
textarea{resize:vertical;min-height:80px}
.hint{font-size:11px;color:var(--muted);margin-top:2px}
.dollar{position:relative}.dollar input{padding-left:22px}
.dollar::before{content:'$';position:absolute;left:9px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:13px;pointer-events:none}

/* RADIO GROUPS */
.rgroup{display:flex;flex-wrap:wrap;gap:8px}
.ropt{position:relative}
.ropt input{position:absolute;opacity:0;width:0;height:0}
.ropt label{display:block;padding:8px 16px;border:2px solid var(--border);border-radius:4px;cursor:pointer;font-size:12px;font-weight:600;letter-spacing:0;text-transform:none;color:var(--ink);background:var(--white);transition:all .15s}
.ropt input:checked+label{background:var(--brown);color:#FAF7F0;border-color:var(--brown)}
.ropt label:hover{border-color:var(--tan)}

/* HORSE LIST */
.horse-list{display:flex;flex-direction:column;gap:10px}
.horse-row{display:grid;grid-template-columns:1fr 60px 60px 1fr auto;gap:10px;align-items:center;padding:10px;background:var(--cream);border:1px solid var(--border);border-radius:4px}
.horse-row input{margin:0}
.del-btn{background:none;border:1.5px solid var(--rust-lt);color:var(--rust);border-radius:3px;padding:5px 9px;cursor:pointer;font-size:13px;transition:all .15s}
.del-btn:hover{background:var(--rust-lt)}
.add-btn{padding:7px 16px;background:transparent;border:2px dashed var(--border);color:var(--muted);font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;border-radius:3px;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:6px}
.add-btn:hover{border-color:var(--tan);color:var(--brown)}

/* KPI STRIP */
.kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;margin:16px 0}
.kpi{padding:14px 16px;border-radius:5px;border:1.5px solid var(--border);background:var(--white)}
.kpi.hi{border-top:3px solid var(--sage);background:var(--sage-lt)}
.kpi.lo{border-top:3px solid var(--rust);background:var(--rust-lt)}
.kpi.mid-c{border-top:3px solid var(--tan)}
.kpi.info{border-top:3px solid var(--sky)}
.kl{font-size:10px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:var(--muted);margin-bottom:4px}
.kv{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:700;line-height:1;color:var(--brown)}
.ks{font-size:11px;color:var(--muted);margin-top:3px}

/* INSIGHT BOXES */
.ins{padding:12px 14px;border-radius:4px;margin:8px 0;display:flex;gap:10px;font-size:13px;line-height:1.6}
.ins .ico{font-size:16px;flex-shrink:0;margin-top:1px}
.ig{background:var(--sage-lt);border-left:3px solid var(--sage);color:#1A3A10}
.iw{background:var(--gold-lt);border-left:3px solid var(--gold);color:#4A3000}
.ib{background:var(--rust-lt);border-left:3px solid var(--rust);color:#5A1000}
.ii{background:var(--sky-lt);border-left:3px solid var(--sky);color:#0A2850}

/* COMPARISON TABLE */
table.cmp{width:100%;border-collapse:collapse}
table.cmp th{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);padding:8px 12px;border-bottom:2px solid var(--border);font-weight:700;text-align:left}
table.cmp th.r{text-align:right}
table.cmp td{padding:8px 12px;border-bottom:1px solid #EDE4C0;font-size:13px}
table.cmp td.r{text-align:right;font-weight:600}
table.cmp tr.tot td{background:var(--brown);color:#FAF7F0;font-weight:700;font-family:'Cormorant Garamond',serif;font-size:16px}
table.cmp tr.tot td.r{color:var(--tan)}
table.cmp tr.sec td{background:var(--cream);font-weight:700;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);padding:10px 12px 4px}
.pos{color:var(--sage)!important;font-weight:700}.neg{color:var(--rust)!important;font-weight:700}

/* PRICING SUGGESTION */
.pricing-band{display:flex;align-items:center;gap:10px;padding:12px;background:var(--tan-lt);border:1.5px solid var(--border);border-radius:4px;margin:8px 0}
.band-range{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;color:var(--brown);white-space:nowrap}
.band-label{font-size:12px;color:var(--muted)}
.band-pick{margin-left:auto;display:flex;align-items:center;gap:6px}
.band-pick label{font-size:11px}

/* PERKS */
.perk-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;margin:10px 0}
.perk-opt{position:relative}
.perk-opt input{position:absolute;opacity:0}
.perk-opt label{display:block;padding:8px 12px;border:1.5px solid var(--border);border-radius:4px;cursor:pointer;font-size:12px;color:var(--ink);background:var(--white);transition:all .12s}
.perk-opt input:checked+label{background:var(--sage-lt);border-color:var(--sage);color:var(--sage)}
.perk-opt label:hover{border-color:var(--tan)}

/* AGREEMENT */
.agreement-box{background:var(--white);border:1.5px solid var(--border);border-radius:4px;padding:20px;font-size:13px;line-height:1.8;max-height:500px;overflow-y:auto;white-space:pre-wrap;font-family:'DM Sans',sans-serif}
.agreement-box h3{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:700;margin:16px 0 8px;color:var(--brown)}
.agreement-box p{margin-bottom:10px}
.agreement-tabs{display:flex;gap:4px;margin-bottom:0}
.atab{padding:8px 16px;border:1.5px solid var(--border);border-bottom:none;border-radius:4px 4px 0 0;cursor:pointer;font-size:12px;font-weight:600;background:var(--cream);transition:all .15s;color:var(--muted)}
.atab.active{background:var(--white);color:var(--brown);border-color:var(--border)}

/* DISCLAIMER */
.disclaimer-box{background:#FFF8E8;border:2px solid var(--tan);border-radius:6px;padding:20px;margin-bottom:20px}
.disclaimer-box h3{font-family:'Cormorant Garamond',serif;font-size:18px;color:var(--brown);margin-bottom:10px}
.sign-row{display:flex;gap:12px;align-items:center;margin-top:14px;flex-wrap:wrap}
.sign-row input[type=text]{flex:1;min-width:200px;background:var(--white)}
.sign-row input[type=date]{width:160px;background:var(--white)}

/* SCHEDULE VIZ */
.schedule-grid{display:grid;gap:4px;margin:12px 0}
.sg-day{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);padding:4px 0}
.sg-slot{border-radius:3px;padding:5px 8px;font-size:11px;font-weight:600;line-height:1.3}
.sg-group{background:var(--sage-lt);color:var(--sage);border:1px solid #88BB60}
.sg-private{background:var(--gold-lt);color:var(--gold);border:1px solid #CCA020}
.sg-intro{background:var(--sky-lt);color:var(--sky);border:1px solid #6096D0}
.sg-empty{background:var(--cream);border:1px dashed var(--border);color:var(--muted);font-size:10px}

/* NAV */
.nav{display:flex;gap:10px;margin-top:24px;padding-top:18px;border-top:1.5px solid var(--border);align-items:center}
.sp{flex:1}
.btn{padding:10px 22px;font-family:'DM Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;border:none;border-radius:3px;transition:all .18s}
.btn-p{background:var(--brown);color:#FAF7F0}.btn-p:hover{background:var(--mid)}
.btn-s{background:transparent;border:2px solid var(--border);color:var(--muted)}.btn-s:hover{border-color:var(--brown);color:var(--brown)}
.btn-g{background:var(--sage);color:#fff}.btn-g:hover{background:#2D4A1E}
.btn-tan{background:var(--tan);color:#fff}.btn-tan:hover{background:var(--gold)}

/* AI LOADING */
.ai-loading{display:flex;align-items:center;gap:10px;padding:14px;background:var(--sky-lt);border-radius:4px;font-size:13px;color:var(--sky)}
.spinner{width:18px;height:18px;border:2px solid rgba(26,74,128,.2);border-top-color:var(--sky);border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}

/* MEMBERSHIP TABLE */
.mem-table{width:100%;border-collapse:collapse;margin:10px 0}
.mem-table th{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);padding:8px 10px;border-bottom:2px solid var(--border);text-align:left;background:var(--cream)}
.mem-table th.r{text-align:right}
.mem-table td{padding:7px 8px;border-bottom:1px solid #EDE4C0;vertical-align:middle}
.mem-table tr:last-child td{border-bottom:none}
.mem-table td input{padding:6px 9px;font-size:13px;margin:0}
.mem-table .rev-cell{font-family:'Cormorant Garamond',serif;font-size:15px;font-weight:700;color:var(--sage);text-align:right;padding-right:10px;white-space:nowrap}
.mem-total-row td{background:var(--tan-lt);font-weight:700;border-top:2px solid var(--border)}
.mem-total-rev{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:700;color:var(--brown);text-align:right;padding-right:10px}

.lesson-type-badge{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:12px;font-size:11px;font-weight:700}
.lt-private{background:var(--gold-lt);color:var(--gold)}
.lt-group{background:var(--sage-lt);color:var(--sage)}
.lt-semi{background:#F0E4FA;color:#6820B0}
.lt-eval{background:var(--sky-lt);color:var(--sky)}

/* PRINT */
@media print{.hdr,.nav,.phase-track,.prog-bar{display:none!important}.phase{display:block!important}}

/* RESPONSIVE */
@media(max-width:600px){.horse-row{grid-template-columns:1fr 1fr;grid-template-rows:auto auto auto}.fg.w2,.fg.w3{flex:1 0 100%}}
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-inner">
    <div class="logo">🐴 Riding School <em>Revenue Optimizer</em></div>
    <div class="phase-track" id="phaseTrack"></div>
  </div>
</div>
<div class="prog-bar"><div class="prog-fill" id="progFill" style="width:16%"></div></div>

<div class="app">

<!-- ═══════════════════════════════════════════
  PHASE 0 — CURRENT STATE
═══════════════════════════════════════════ -->
<div class="phase on" id="ph0">
  <div class="ph">
    <div class="ph-num">Phase 1 of 6</div>
    <div class="ph-title">Your Current Situation</div>
    <div class="ph-sub">Let's start with what you have now — pricing, horses, students, and schedule. We'll calculate your revenue and two key performance indicators every riding school should track.</div>
  </div>

  <div class="card">
    <div class="card-h"><span class="ico">🏫</span><span class="ttl">Your School</span></div>
    <div class="card-b">

      <!-- Row 1: Name + Website -->
      <div class="frow">
        <div class="fg w2"><label>School Name</label><input type="text" id="schoolName" placeholder="Flying Changes Riding School"></div>
        <div class="fg w2"><label>Website</label><input type="text" id="schoolWebsite" placeholder="www.flyingchanges.com"></div>
      </div>

      <!-- Row 2: Address -->
      <div class="frow">
        <div class="fg" style="flex:1 0 100%"><label>Street Address</label><input type="text" id="schoolAddress" placeholder="1234 Riding Lane"></div>
      </div>
      <div class="frow">
        <div class="fg w3"><label>City</label><input type="text" id="schoolCity" placeholder="Austin"></div>
        <div class="fg w3"><label>State / Province</label><input type="text" id="schoolState" placeholder="Texas" maxlength="50"></div>
        <div class="fg w3"><label>ZIP / Postal Code</label><input type="text" id="schoolZip" placeholder="78701" maxlength="12"></div>
      </div>

      <!-- Row 3: Property -->
      <div class="frow" style="align-items:flex-end">
        <div class="fg w3">
          <label>Property Status</label>
          <select id="schoolPropertyStatus" onchange="renderPropertyPayment()">
            <option value="own">Own</option>
            <option value="rent">Rent</option>
            <option value="lease_to_own">Lease to Own</option>
          </select>
        </div>
        <div class="fg w3" id="propertyPaymentField">
          <!-- rendered by renderPropertyPayment() -->
        </div>
        <div class="fg w3">
          <label>Total Acres</label>
          <input type="number" id="schoolAcres" min="0" step="0.1" placeholder="e.g. 25">
        </div>
      </div>

      <!-- Row 4: Owners -->
      <div style="margin-top:6px">
        <div style="font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:8px">Principal Owners</div>
        <table style="width:100%;border-collapse:separate;border-spacing:0 5px">
          <thead>
            <tr style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)">
              <th style="padding:0 8px 4px 10px;text-align:left">Owner Name</th>
              <th style="padding:0 8px 4px;text-align:left;width:130px">Ownership %</th>
              <th style="padding:0 8px 4px;text-align:left">Role / Title</th>
              <th style="width:36px"></th>
            </tr>
          </thead>
          <tbody id="ownersTableBody"></tbody>
        </table>
        <button class="add-btn" onclick="addOwner()" style="margin-top:4px">＋ Add Owner</button>
        <div id="ownershipWarning" style="display:none;margin-top:8px;font-size:12px;color:var(--rust);padding:6px 10px;background:#FFF0ED;border-left:3px solid var(--rust);border-radius:0 3px 3px 0"></div>
      </div>

    </div>
  </div>

  <!-- BARN ACCOMMODATIONS -->
  <div class="card">
    <div class="card-h"><span class="ico">🐴</span><span class="ttl">Horse Accommodations</span><span class="sub">Build your virtual barn</span></div>
    <div class="card-b">

      <!-- STEP 1: Setup -->
      <div id="barnCountStep">
        <p style="font-size:13px;color:var(--muted);margin-bottom:16px">Name each barn and enter how many stalls it has, then add your shared paddocks, field board spots, and any other accommodations.</p>

        <!-- BARNS -->
        <div style="font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:8px">🏠 Barns &amp; Stalls</div>
        <table style="width:100%;border-collapse:separate;border-spacing:0 6px;margin-bottom:4px" id="barnSetupTable">
          <thead>
            <tr style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)">
              <th style="padding:0 8px 4px 10px;text-align:left">Barn Name</th>
              <th style="padding:0 8px 4px;text-align:left;width:130px">Number of Stalls</th>
              <th style="width:36px"></th>
            </tr>
          </thead>
          <tbody id="barnSetupRows"></tbody>
        </table>
        <button class="add-btn" onclick="addBarnEntry()" style="margin-bottom:18px">＋ Add Another Barn</button>

        <!-- SHARED ACCOMMODATIONS -->
        <div style="font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:8px">Other Accommodations (farm-wide)</div>
        <table style="width:100%;border-collapse:separate;border-spacing:0 6px">
          <thead>
            <tr style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)">
              <th style="padding:0 8px 4px 10px;text-align:left">Type</th>
              <th style="padding:0 8px 4px;text-align:left;width:130px">How Many?</th>
              <th style="padding:0 8px 4px;text-align:left">Description</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td style="padding:7px 10px 7px 12px;background:var(--sage-lt);border:1px solid #88BB60;border-right:none;border-radius:4px 0 0 4px"><span style="font-size:13px;font-weight:600;color:var(--sage)">🌿 Paddocks</span></td>
              <td style="padding:7px 8px;background:var(--sage-lt);border-top:1px solid #88BB60;border-bottom:1px solid #88BB60">
                <input type="number" id="barnCount_paddock" value="0" min="0" max="200" style="width:100%;padding:6px 8px;font-size:14px;text-align:center;border:1.5px solid #88BB60;background:rgba(255,255,255,.8);border-radius:3px;color:var(--brown)">
              </td>
              <td style="padding:7px 12px;background:var(--sage-lt);border:1px solid #88BB60;border-left:none;border-radius:0 4px 4px 0;font-size:12px;color:var(--muted)">Individual fenced turnout paddocks</td>
            </tr>
            <tr>
              <td style="padding:7px 10px 7px 12px;background:var(--gold-lt);border:1px solid #CCA020;border-right:none;border-radius:4px 0 0 4px"><span style="font-size:13px;font-weight:600;color:var(--gold)">🌾 Field Board</span></td>
              <td style="padding:7px 8px;background:var(--gold-lt);border-top:1px solid #CCA020;border-bottom:1px solid #CCA020">
                <input type="number" id="barnCount_field" value="0" min="0" max="200" style="width:100%;padding:6px 8px;font-size:14px;text-align:center;border:1.5px solid #CCA020;background:rgba(255,255,255,.8);border-radius:3px;color:var(--brown)">
              </td>
              <td style="padding:7px 12px;background:var(--gold-lt);border:1px solid #CCA020;border-left:none;border-radius:0 4px 4px 0;font-size:12px;color:var(--muted)">Open pasture / group field board spots</td>
            </tr>
            <tr>
              <td style="padding:7px 10px 7px 12px;background:var(--sky-lt);border:1px solid #80B8E8;border-right:none;border-radius:4px 0 0 4px"><span style="font-size:13px;font-weight:600;color:var(--sky)">✨ Other</span></td>
              <td style="padding:7px 8px;background:var(--sky-lt);border-top:1px solid #80B8E8;border-bottom:1px solid #80B8E8">
                <input type="number" id="barnCount_other" value="0" min="0" max="200" style="width:100%;padding:6px 8px;font-size:14px;text-align:center;border:1.5px solid #80B8E8;background:rgba(255,255,255,.8);border-radius:3px;color:var(--brown)">
              </td>
