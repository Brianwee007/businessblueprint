function refreshPaygoRevenue(){
  const lessonTypeIds = ['pricePrivate','priceGroup','priceSemi','priceEval'];
  let totalRev = 0, totalStudents = 0;
  lessonTypeIds.forEach(id => {
    const price = parseFloat(document.getElementById(`v_${id}`)?.value)||0;
    const students = parseInt(document.getElementById(`paygo_students_${id}`)?.value)||0;
    const monthlyRev = price * students * 4.3;
    totalRev += monthlyRev;
    totalStudents += students;
    const revEl = document.getElementById(`paygo_rev_${id}`);
    if(revEl) revEl.textContent = monthlyRev > 0 ? '$'+fmt(monthlyRev) : '—';
  });
  const trEl = document.getElementById('paygo_total_rev');
  const tsEl = document.getElementById('paygo_total_students');
  if(trEl) trEl.textContent = totalRev > 0 ? '$'+fmt(totalRev) : '—';
  if(tsEl) tsEl.textContent = totalStudents > 0 ? totalStudents+' students' : '—';
  // Sync totalStudents hidden
  syncHidden('totalStudents', totalStudents);
}

