function addMemRow(){
  membershipRows.push({id: nextMemId++, price:0, lessons:1, students:0});
  renderPricingCard();
}

function removeMemRow(id){
  if(membershipRows.length <= 1){ alert('Keep at least one membership tier.'); return; }
  membershipRows = membershipRows.filter(r => r.id !== id);
  renderPricingCard();
}

function updateMemRow(id, field, val){
  const r = membershipRows.find(r => r.id === id);
  if(!r) return;
  r[field] = field === 'price' ? parseFloat(val)||0 : parseInt(val)||0;
  // Update just the revenue cell and totals without full re-render
  const row = document.querySelector(`tr[data-mem-id="${id}"]`);
  if(row){
    const revCell = row.querySelector('.rev-cell');
    if(revCell) revCell.textContent = '$'+fmt(r.price * r.students);
  }
  // Update totals
  const totalRev = membershipRows.reduce((s,r)=> s + r.price * r.students, 0);
  const totalStudents = membershipRows.reduce((s,r)=> s + r.students, 0);
  const totalRevEl = document.querySelector('.mem-total-rev');
  if(totalRevEl) totalRevEl.textContent = '$'+fmt(totalRev)+'/mo';
  const totalStudEl = document.querySelector('.mem-total-row td:nth-child(3)');
  if(totalStudEl) totalStudEl.textContent = totalStudents;
  const totalLabelEl = document.querySelector('.mem-total-row td:nth-child(1)');
  if(totalLabelEl) totalLabelEl.textContent = `Total — ${totalStudents} members`;
  syncHidden('totalStudents', totalStudents);
}

function getHidden(id){
  return document.getElementById(id)?.value || '';
}

function syncHidden(id, val){
  const el = document.getElementById(id);
  if(el) el.value = val;
}

function getMemRevenue(){
  // For membership model: total monthly rev = sum of price × students
  const model = getChargeModel();
  if(model === 'membership' || model === 'mixed'){
    return membershipRows.reduce((s,r) => s + r.price * r.students, 0);
  }
  return null; // use per-lesson calc
}

function getMemStudentCount(){
  return membershipRows.reduce((s,r) => s + r.students, 0);
}

