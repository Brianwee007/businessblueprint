// BARN / ACCOMMODATION MANAGEMENT
// ═══════════════════════════════════════════════
const ACCOM_TYPES = {
  stall:   {label:'🏠 Stall',       color:'#F5EDD0',        border:'#CCA060'},
  paddock: {label:'🌿 Paddock',     color:'var(--sage-lt)', border:'#88BB60'},
  field:   {label:'🌾 Field Board', color:'var(--gold-lt)', border:'#CCA020'},
  other:   {label:'✨ Other',       color:'var(--sky-lt)',  border:'#80B8E8'},
};

const STALL_USES = [
  {value:'lesson',        label:'🐴 Lesson Horse'},
  {value:'boarder',       label:'🏡 Boarder'},
  {value:'boarder_lesson',label:'🐴🏡 Boarder / Lesson Horse'},
  {value:'personal',      label:'👤 Personal Horse'},
  {value:'investment',    label:'💰 Investment Horse'},
  {value:'broodmare',     label:'🤱 Broodmare'},
  {value:'stallion',      label:'⚡ Stallion'},
  {value:'homebred',      label:'🌱 Homebred'},
  {value:'empty',         label:'— Empty'},
];

const SHOWS_BOARD    = ['boarder', 'boarder_lesson'];
const SHOWS_TRAINING = ['boarder', 'boarder_lesson', 'personal', 'investment', 'broodmare', 'stallion', 'homebred'];

// Barn entries (named barns with stall counts)
let barnEntries = [
  {id:1, name:'Barn 1', stalls:12},
  {id:2, name:'Barn 2', stalls:8},
];
let nextBarnEntryId = 3;

// Flat stall rows (built from barnEntries + shared counts)
let stallRows = [];
let nextStallId = 1;

function renderBarnSetupRows(){
  const tbody = document.getElementById('barnSetupRows');
  if(!tbody) return;
  tbody.innerHTML = barnEntries.map(b => `
    <tr>
      <td style="padding:7px 8px 7px 10px;background:#F5EDD0;border:1px solid #CCA060;border-right:none;border-radius:4px 0 0 4px">
        <input type="text" value="${esc(b.name)}" placeholder="e.g. Main Barn"
          style="width:100%;padding:5px 8px;font-size:13px;border:1.5px solid #CCA060;background:rgba(255,255,255,.8);border-radius:3px;color:var(--brown)"
          oninput="updateBarnEntry(${b.id},'name',this.value)">
      </td>
      <td style="padding:7px 8px;background:#F5EDD0;border-top:1px solid #CCA060;border-bottom:1px solid #CCA060">
        <input type="number" value="${b.stalls}" min="0" max="200"
          style="width:100%;padding:5px 8px;font-size:14px;text-align:center;border:1.5px solid #CCA060;background:rgba(255,255,255,.8);border-radius:3px;color:var(--brown)"
          oninput="updateBarnEntry(${b.id},'stalls',this.value)">
      </td>
      <td style="padding:7px 8px 7px 4px;background:#F5EDD0;border:1px solid #CCA060;border-left:none;border-radius:0 4px 4px 0">
        ${barnEntries.length > 1
          ? `<button class="del-btn" onclick="removeBarnEntry(${b.id})">✕</button>`
          : `<span style="display:inline-block;width:32px"></span>`}
      </td>
    </tr>`).join('');
}

function addBarnEntry(){
  const n = barnEntries.length + 1;
  barnEntries.push({id:nextBarnEntryId++, name:`Barn ${n}`, stalls:0});
  renderBarnSetupRows();
}

function removeBarnEntry(id){
  barnEntries = barnEntries.filter(b => b.id !== id);
  renderBarnSetupRows();
}

function updateBarnEntry(id, field, val){
  const b = barnEntries.find(b => b.id === id);
  if(b) b[field] = field === 'name' ? val : (parseInt(val)||0);
}

function buildBarnFromCounts(){
  // Read latest values directly from DOM inputs
  barnEntries.forEach(b => {
    const nameEl  = document.querySelector(`#barnSetupRows input[type=text]`);
    // Already updated via oninput
  });

  const paddocks = parseInt(document.getElementById('barnCount_paddock')?.value)||0;
  const fields   = parseInt(document.getElementById('barnCount_field')?.value)||0;
  const others   = parseInt(document.getElementById('barnCount_other')?.value)||0;
  const totalStalls = barnEntries.reduce((s,b)=>s+(b.stalls||0),0);

  if(totalStalls + paddocks + fields + others === 0){
    document.getElementById('barnCountHint').textContent = 'Please enter at least one accommodation.';
    return;
  }

  stallRows = [];
  nextStallId = 1;

  // Stalls — grouped by barn
  barnEntries.forEach(b => {
    for(let i=0; i < (b.stalls||0); i++){
      stallRows.push({id:nextStallId++, type:'stall', barnName:b.name, use:'empty', name:'', board:0, training:0});
    }
  });
  // Shared accommodations
  for(let i=0; i<paddocks; i++) stallRows.push({id:nextStallId++, type:'paddock', barnName:'', use:'empty', name:'', board:0, training:0});
  for(let i=0; i<fields;   i++) stallRows.push({id:nextStallId++, type:'field',   barnName:'', use:'empty', name:'', board:0, training:0});
  for(let i=0; i<others;   i++) stallRows.push({id:nextStallId++, type:'other',   barnName:'', use:'empty', name:'', board:0, training:0});

  document.getElementById('barnCountStep').style.display  = 'none';
  document.getElementById('barnDetailStep').style.display = 'block';
  renderBarnTable();
}

function resetBarn(){
  document.getElementById('barnCountStep').style.display  = 'block';
  document.getElementById('barnDetailStep').style.display = 'none';
}

function updateStall(id, field, val){
  const s = stallRows.find(s => s.id === id);
  if(!s) return;
  s[field] = (field === 'use' || field === 'name') ? val : (parseFloat(val)||0);
  if(field === 'use') renderBarnTable();
  else refreshBarnSummary();
}

function renderBarnTable(){
  const tbody = document.getElementById('barnTableBody');
  if(!tbody) return;

  let html = '';
  let lastSection = null; // tracks "Barn 1", "Barn 2", "Paddocks", etc.

  stallRows.forEach(s => {
    const t       = ACCOM_TYPES[s.type] || ACCOM_TYPES.stall;
    const showB   = SHOWS_BOARD.includes(s.use);
    const showT   = SHOWS_TRAINING.includes(s.use);
    const isEmpty = s.use === 'empty';
    const useOpts = STALL_USES.map(u =>
      `<option value="${u.value}"${s.use===u.value?' selected':''}>${u.label}</option>`).join('');

    // Determine section label
    let sectionKey, sectionLabel, sectionCount;
    if(s.type === 'stall'){
      sectionKey   = `barn_${s.barnName}`;
      sectionLabel = `🏠 ${s.barnName}`;
      sectionCount = stallRows.filter(r=>r.type==='stall'&&r.barnName===s.barnName).length;
    } else {
      sectionKey   = s.type;
      sectionLabel = t.label + 's';
      sectionCount = stallRows.filter(r=>r.type===s.type).length;
    }

    if(sectionKey !== lastSection){
      html += `<tr><td colspan="6" style="padding:10px 10px 3px;font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);border-bottom:1.5px solid var(--border)">
        ${sectionLabel} <span style="font-weight:400">(${sectionCount})</span>
      </td></tr>`;
      lastSection = sectionKey;
    }

    // Number within this section
    const secRows = s.type === 'stall'
      ? stallRows.filter(r=>r.type==='stall'&&r.barnName===s.barnName)
      : stallRows.filter(r=>r.type===s.type);
    const typeIdx = secRows.findIndex(r=>r.id===s.id) + 1;

    // Location label: barn name for stalls, type label for others
    const locationLabel = s.type === 'stall' ? s.barnName : t.label;

    html += `<tr>
      <td style="padding:5px 4px 5px 10px;background:${t.color};border:1px solid ${t.border};border-right:none;border-radius:4px 0 0 4px;font-size:11px;font-weight:700;color:var(--muted);text-align:center;width:46px">${typeIdx}</td>
      <td style="padding:5px 6px;background:${t.color};border-top:1px solid ${t.border};border-bottom:1px solid ${t.border};width:155px">
        <span style="font-size:12px;font-weight:600;color:var(--brown)">${locationLabel}</span>
      </td>
      <td style="padding:5px 6px;background:${t.color};border-top:1px solid ${t.border};border-bottom:1px solid ${t.border};width:165px">
        <select style="width:100%;padding:4px;font-size:12px;border:1.5px solid ${t.border};background:rgba(255,255,255,.8);border-radius:3px;color:var(--brown)"
          onchange="updateStall(${s.id},'use',this.value)">${useOpts}</select>
      </td>
      <td style="padding:5px 6px;background:${t.color};border-top:1px solid ${t.border};border-bottom:1px solid ${t.border};width:155px">
        <input type="text" value="${esc(s.name)}" placeholder="${isEmpty?'—':'Horse name…'}" ${isEmpty?'disabled':''}
          style="width:100%;padding:4px 7px;font-size:12px;border:1.5px solid ${t.border};background:${isEmpty?'rgba(200,200,200,.25)':'rgba(255,255,255,.8)'};border-radius:3px;color:${isEmpty?'var(--muted)':'var(--brown)'}"
          oninput="updateStall(${s.id},'name',this.value)">
      </td>
      <td style="padding:5px 6px;background:${t.color};border-top:1px solid ${t.border};border-bottom:1px solid ${t.border};width:125px">
        ${showB ? `<div style="position:relative">
          <span style="position:absolute;left:7px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:11px;pointer-events:none">$</span>
          <input type="number" value="${s.board||''}" min="0" placeholder="0"
            style="width:100%;padding:4px 6px 4px 16px;font-size:12px;border:1.5px solid ${t.border};background:rgba(255,255,255,.8);border-radius:3px;color:var(--brown)"
            oninput="updateStall(${s.id},'board',this.value)"></div>`
        : `<span style="font-size:12px;color:var(--muted);padding-left:6px">—</span>`}
      </td>
      <td style="padding:5px 10px 5px 6px;background:${t.color};border:1px solid ${t.border};border-left:none;border-radius:0 4px 4px 0">
        ${showT ? `<div style="position:relative">
          <span style="position:absolute;left:7px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:11px;pointer-events:none">$</span>
          <input type="number" value="${s.training||''}" min="0" placeholder="0"
            style="width:100%;padding:4px 6px 4px 16px;font-size:12px;border:1.5px solid ${t.border};background:rgba(255,255,255,.8);border-radius:3px;color:var(--brown)"
            oninput="updateStall(${s.id},'training',this.value)"></div>`
        : `<span style="font-size:12px;color:var(--muted);padding-left:6px">—</span>`}
      </td>
    </tr>`;
  });

  tbody.innerHTML = html;
  refreshBarnSummary();
}

function refreshBarnSummary(){
  const total    = stallRows.length;
  const lessons   = stallRows.filter(s=>s.use==='lesson'||s.use==='boarder_lesson').length;
  const boarders  = stallRows.filter(s=>s.use==='boarder'||s.use==='boarder_lesson').length;
  const personal  = stallRows.filter(s=>s.use==='personal').length;
  const empty    = stallRows.filter(s=>s.use==='empty').length;
  const boardRev    = stallRows.filter(s=>s.use==='boarder').reduce((sum,s)=>sum+(s.board||0),0);
  const trainingRev = stallRows.filter(s=>SHOWS_TRAINING.includes(s.use)).reduce((sum,s)=>sum+(s.training||0),0);
  const totalRev    = boardRev + trainingRev;

  // Capacity badge
  const badge = document.getElementById('barnCapacityBadge');
  if(badge){
    const stalls   = stallRows.filter(s=>s.type==='stall').length;
    const paddocks = stallRows.filter(s=>s.type==='paddock').length;
    const fields   = stallRows.filter(s=>s.type==='field').length;
    const others   = stallRows.filter(s=>s.type==='other').length;
    badge.innerHTML = `<strong style="color:var(--brown);font-size:14px">${total}</strong> <span style="color:var(--muted)">total capacity</span>`
      + (stalls   ? ` · <strong style="color:var(--brown)">${stalls}</strong> <span style="color:var(--muted)">stalls</span>` : '')
      + (paddocks ? ` · <strong style="color:var(--sage)">${paddocks}</strong> <span style="color:var(--muted)">paddocks</span>` : '')
      + (fields   ? ` · <strong style="color:var(--gold)">${fields}</strong> <span style="color:var(--muted)">field board</span>` : '')
      + (others   ? ` · <strong style="color:var(--sky)">${others}</strong> <span style="color:var(--muted)">other</span>` : '');
  }

  const summary = document.getElementById('barnSummary');
  if(!summary) return;
  if(total === 0){ summary.style.display='none'; return; }
  summary.style.display = 'block';
  summary.innerHTML = `<div style="display:flex;flex-wrap:wrap;gap:16px;align-items:center;padding:10px 12px;background:var(--cream);border:1px solid var(--border);border-radius:4px;font-size:12px">
    <div style="display:flex;gap:16px;flex-wrap:wrap;flex:1">
      ${lessons  ? `<span>🐴 <strong style="color:var(--brown)">${lessons}</strong> lesson horse${lessons!==1?'s':''}</span>` : ''}
      ${boarders ? `<span>🏡 <strong style="color:var(--brown)">${boarders}</strong> boarder${boarders!==1?'s':''}</span>` : ''}
      ${personal ? `<span>👤 <strong style="color:var(--brown)">${personal}</strong> personal</span>` : ''}
      ${empty    ? `<span style="color:var(--muted)">⬜ ${empty} empty</span>` : ''}
    </div>
    ${totalRev > 0 ? `<div style="text-align:right">
      <span style="color:var(--muted)">Board + training: </span>
      <strong style="font-family:'Cormorant Garamond',serif;font-size:16px;color:var(--sage)">$${fmt(totalRev)}/mo</strong>
    </div>` : ''}
  </div>`;
}

function renderBarn(){ /* no-op — barn uses buildBarnFromCounts flow */ }

