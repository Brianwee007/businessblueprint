  if(recs)      html += `<div class="card"><div class="card-h"><span class="ico">🎯</span><span class="ttl">Action Plan</span></div><div class="card-b"><div style="font-size:13px;line-height:1.8;white-space:pre-wrap">${recs}</div></div></div>`;

  html += `
    <div class="card" style="margin-top:16px">
      <div class="card-h" style="justify-content:space-between;flex-wrap:wrap;gap:8px">
        <span><span class="ico">\u{1F5D3}\uFE0F</span><span class="ttl">Goal Schedule Calendar</span></span>
